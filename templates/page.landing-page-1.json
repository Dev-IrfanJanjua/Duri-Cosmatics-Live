        "faq_TxPkBr": {
          "type": "faq",
          "settings": {
            "question": "What's the difference between Rejuvacote 1 and Rejuvacote 2?",
            "answer": "Rejuvacote 1 is our Maximum Strength Formula, designed for very weak, damaged nails that need intensive strengthening.\nRejuvacote 2 is our Balanced Repair Formula, created for thin, peeling, or sensitive nails that need gentle repair and flexibility.\n\nBoth work as a base and top coat, but the choice depends on whether your nails need intensive strength (R1) or balanced, flexible repair (R2)."
          }
        },
        "faq_9MUHxH": {
          "type": "faq",
          "settings": {
            "question": "How do I use my bundle for best results?",
            "answer": "Start with clean, dry nails. Apply your treatment (Rejuvacote 1 or 2) as a base coat, follow with 1–2 coats of your nail color, and finish with a top coat to seal and protect. Reapply your treatment or top coat every 1–2 days to maintain strength and shine. For best results, follow a consistent routine and remove and restart your manicure every 5–7 days."
          }
        },
        "faq_YjzTkc": {
          "type": "faq",
          "settings": {
            "question": "How often should I use Rejuvacote?",
            "answer": "Nail treatments work best with consistent use. Apply daily or every other day as part of your routine, either alone or over polish. For treatment cycles like Rejuvacote, we recommend a 7-day routine, building layers throughout the week, then removing and starting fresh."
          }
        },
        "faq_AJ8g43": {
          "type": "faq",
          "settings": {
            "question": "Are your products safe for sensitive nails?",
            "answer": "Yes, Rejuvacote 2 is specifically designed for thin, peeling, or more sensitive nails. Its Balanced Repair Formula strengthens while maintaining flexibility, helping to avoid the stiffness that can lead to further breakage. If you have highly sensitive skin or nails, we recommend starting with Rejuvacote 2 and monitoring how your nails respond."
          }
        },
