<script>
/* ============================================================
   BundleCollectionPicker — Real-Time Additive Pricing
   ============================================================ */
(function () {
  'use strict';

  var q = (sel, root) => (root || document).querySelector(sel);
  var qq = (sel, root) => Array.from((root || document).querySelectorAll(sel));

  const EMPTY_SLOT_SVG = `
    <span class="selected-slot__placeholder">
    {% if block.settings.placeholder  != blank %}
     {{ block.settings.placeholder | image_url: width: 1600 | image_tag:
          widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
          alt: "image",
          loading: "lazy"
      }}
    {% else %}
      <svg width="32" height="48" viewBox="0 0 32 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="0" width="16" height="6" rx="3" fill="#ddd"/>
        <rect x="5" y="5" width="22" height="43" rx="4" fill="#e8e8e8"/>
      </svg>
    {% endif %}
    </span>`;

  function BundleUI(section) {
    this.section = section;
    this.sectionId = section.dataset.sectionId;
    this.activeTier = 2; 
    this.selectedItems = [];

    this.tierBtns = qq('.bundle-tier', section);
    this.productBtns = qq('.bundle-product', section);
    this.swatches = qq('.js-color-swatch', section);
    this.tray = q('.js-selected-tray', section);
    this.themeAtcBtn = q('#ProductSubmitButton-' + this.sectionId);
    
    this.collTrigger = q('.js-collection-trigger', section);
    this.collDropdown = q('.bcp-dropdown', section);
    this.collLabel = q('.js-active-coll-label', section);

    this.init();
  }

  BundleUI.prototype.init = function() {
    this._initTier();
    this._initProductBtns();
    this._initSwatches();
    this._initCollectionDropdown();
    this._renderTray();
    this._updateAtcState();
    
    if (this.productBtns[0]) this._setProduct(this.productBtns[0]);
    const firstColl = q('.bcp-dropdown__item', this.collDropdown);
    if (firstColl) this._selectCollection(firstColl);

    this._updatePricing();
  };

  BundleUI.prototype._parseMoney = function(str) {
    if (!str) return 0;
    // Cleans strings like "$12.50" or "Rs. 12.00" into 12.50
    return parseFloat(String(str).replace(/[^0-9.-]+/g,"")) || 0;
  };

  BundleUI.prototype._formatMoney = function(num) {
    return '$' + num.toFixed(2);
  };

  /**
   * REAL-TIME ADDITIVE PRICING
   * Adds base product + each item as it is selected.
   */
  BundleUI.prototype._updatePricing = function() {
    const activeBase = this.productBtns.find(b => b.classList.contains('is-active'));
    const basePrice = activeBase ? this._parseMoney(activeBase.dataset.price) : 0;
    const baseCompare = activeBase ? this._parseMoney(activeBase.dataset.comparePrice) : 0;

    this.tierBtns.forEach(btn => {
      const tierSize = parseInt(btn.dataset.tier, 10);
      
      // Look at the items currently in the tray that fall within this tier's range
      const itemsForThisTier = this.selectedItems.slice(0, tierSize);
      
      let currentTotal = basePrice;
      let currentCompare = baseCompare;

      if (this.selectedItems.length > 0) {
        // Add only the items that are actually selected
        itemsForThisTier.forEach(item => {
          currentTotal += this._parseMoney(item.price);
          currentCompare += this._parseMoney(item.com_price);
        });

        // SCENARIO: If user is building a larger bundle, 
        // we show the partial price of the smaller tiers based on items 1 & 2.
      } else {
        // If nothing at all is selected, show the default placeholder from customizer
        currentTotal = this._parseMoney(btn.dataset.defaultPrice);
        currentCompare = this._parseMoney(btn.dataset.defaultCompare);
      }

      const priceEl = btn.querySelector('.bundle-tier__priceNot');
      const compareEl = btn.querySelector('.bundle-tier__compareNot');

      if (priceEl) priceEl.textContent = this._formatMoney(currentTotal);
      if (compareEl) {
        compareEl.textContent = currentCompare > currentTotal ? this._formatMoney(currentCompare) : '';
      }
    });
  };

  /* --- UI Events --- */

  BundleUI.prototype._initCollectionDropdown = function () {
    if (!this.collTrigger || !this.collDropdown) return;
    this.collTrigger.addEventListener('click', () => {
      const isExpanded = this.collTrigger.getAttribute('aria-expanded') === 'true';
      this.collTrigger.setAttribute('aria-expanded', !isExpanded);
      this.collDropdown.toggleAttribute('hidden');
    });
    qq('.bcp-dropdown__item', this.collDropdown).forEach(item => {
      item.addEventListener('click', () => {
        this._selectCollection(item);
        this.collDropdown.setAttribute('hidden', '');
        this.collTrigger.setAttribute('aria-expanded', 'false');
      });
    });
    document.addEventListener('click', (e) => {
      if (!this.section.contains(e.target)) {
        this.collDropdown.setAttribute('hidden', '');
        this.collTrigger.setAttribute('aria-expanded', 'false');
      }
    });
  };

  BundleUI.prototype._selectCollection = function (item) {
    const handle = item.dataset.collHandle;
    const title = item.dataset.collTitle;
    qq('.bcp-dropdown__item', this.collDropdown).forEach(i => i.classList.toggle('is-active', i === item));
    this.swatches.forEach(sw => {
      sw.style.display = (sw.dataset.collHandle === handle) ? '' : 'none';
    });
    if (this.collLabel) this.collLabel.textContent = title;
  };

  BundleUI.prototype._setTier = function (tier, btn) {
    this.activeTier = tier;
    if (this.selectedItems.length > tier) {
        this.selectedItems = this.selectedItems.slice(0, tier);
        this._syncSwatchStates();
    }
    this.tierBtns.forEach(b => b.classList.toggle('is-active', b === btn));
    this._renderTray();
    this._updateAtcState();
    this._updatePricing(); 
  };

  BundleUI.prototype._initTier = function () {
    this.tierBtns.forEach(btn => {
      btn.addEventListener('click', () => this._setTier(parseInt(btn.dataset.tier, 10), btn));
    });
  };

  BundleUI.prototype._initProductBtns = function () {
    this.productBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        if (!e.target.closest('.bundle-product__info-btn')) {
            this._setProduct(btn);
            this._updatePricing(); 
        }
      });
    });
  };

  BundleUI.prototype._setProduct = function (btn) {
    this.productBtns.forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
    const label = q('.js-selected-product-name', this.section);
    if (label) label.textContent = btn.dataset.productTitle || '';
  };

  BundleUI.prototype._initSwatches = function () {
    this.swatches.forEach(sw => {
      sw.addEventListener('click', () => this._toggleSwatch(sw));
    });
  };

  BundleUI.prototype._toggleSwatch = function (sw) {
    const variantId = sw.dataset.variantId;
    const idx = this.selectedItems.findIndex(i => i.variantId === variantId);

    if (idx !== -1) {
      this.selectedItems.splice(idx, 1);
      sw.classList.remove('is-selected');
    } else {
      if (this.selectedItems.length >= this.activeTier) return;
      this.selectedItems.push({
        variantId: variantId,
        price: sw.dataset.productPrice || '',
        com_price: sw.dataset.productCompare || '',
        handle: sw.dataset.productHandle || '',
        title: sw.dataset.productTitle || '',
        imgSrc: sw.dataset.imgSrc || '',
        imgAlt: sw.dataset.imgAlt || ''
      });
      sw.classList.add('is-selected');
    }
    this._renderTray();
    this._updateAtcState();
    this._updatePricing(); 
  };

  BundleUI.prototype._syncSwatchStates = function () {
    const ids = new Set(this.selectedItems.map(i => i.variantId));
    this.swatches.forEach(sw => sw.classList.toggle('is-selected', ids.has(sw.dataset.variantId)));
  };

  BundleUI.prototype._updateAtcState = function () {
    if (!this.themeAtcBtn) return;
    const ready = (this.selectedItems.length === this.activeTier);
    this.themeAtcBtn.disabled = !ready;
    this.themeAtcBtn.dataset.bundleReady = ready;
  };

  BundleUI.prototype._renderTray = function () {
    if (!this.tray) return;
    let html = '';
    for (let i = 0; i < this.activeTier; i++) {
      const item = this.selectedItems[i];
      if (item) {
        html += `
          <div class="selected-slot is-filled" data-slot="${i}" data-variant-id="${item.variantId}" data-product-handle="${item.handle}" data-price="${item.price}" data-compare-price="${item.com_price}">
            <img src="${item.imgSrc}" alt="${item.imgAlt}" loading="lazy">
            <button class="selected-slot__remove" type="button" data-id="${item.variantId}" aria-label="Remove item">✕</button>
          </div>`;
      } else {
        html += `<div class="selected-slot" data-slot="${i}">${EMPTY_SLOT_SVG}</div>`;
      }
    }
    this.tray.innerHTML = html;
    qq('.selected-slot__remove', this.tray).forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const sw = this.swatches.find(s => s.dataset.variantId === btn.dataset.id);
        if (sw) this._toggleSwatch(sw);
      });
    });
  };

  window.BundleUIInstances = window.BundleUIInstances || {};
  function init() {
    const section = document.getElementById('bundle-section-{{ section.id }}');
    if (section && !section._bcpInit) {
      section._bcpInit = true;
      window.BundleUIInstances['{{ section.id }}'] = new BundleUI(section);
    }
  }
  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);
})();
</script>

