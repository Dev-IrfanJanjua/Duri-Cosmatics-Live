                    <path d="M8.75792 5.26027C9.34153 5.22159 9.78332 4.71723 9.74465 4.13362C9.70597 3.55001 9.2016 3.10821 8.61799 3.14689C8.03438 3.18556 7.59259 3.68993 7.63126 4.27354C7.66994 4.85715 8.17431 5.29895 8.75792 5.26027Z" fill="black"/>
                    </g>
                    <defs>
                    <clipPath id="clip0_8900_4078">
                    <rect width="16" height="16" fill="white"/>
                    </clipPath>
                    </defs>
                </svg>
              </div>
            </button>
          {%- endif -%}

          {%- comment -%} Product 2 {%- endcomment -%}
          {%- if product_2 != blank -%}
            {%- assign cp = product_2 -%}
            <button
              class="bundle-product{% if product_1 == blank %} is-active{% endif %}"
              data-product-id="{{ cp.selected_or_first_available_variant.id }}"
              data-variant-qty="1"
              data-product-handle="{{ cp.handle }}"
              data-product-title="{{ cp.title | escape }}"
              data-price="{{ cp.price | money }}"
              data-compare-price="{{ cp.compare_at_price | money }}"
              type="button"
              aria-pressed="{% if product_1 == blank %}true{% else %}false{% endif %}"
            >
              <div class="bundle-product__img-wrap">
                {%- if cp.featured_image -%}
                  {{- cp.featured_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: cp.title -}}
                {%- endif -%}
              </div>
              <div class="bundle-product__info">
                <span class="bundle-product__name">{{ cp.title }}</span>
                {%- if cp.description != blank -%}
                  <span class="bundle-product__desc">{{ cp.description | strip_html | truncate: 60 }}</span>
                {%- endif -%}
              </div>
              <div
                class="bundle-product__info-btn js-open-popup"
                data-popup-index="2"
                aria-label="More info about {{ cp.title }}"
                title="{{ cp.title | escape }}"
                data-product-title="{{ cp.title | escape }}"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g clip-path="url(#clip0_8900_4078)">
                    <path d="M8 16C6.9203 16 5.87247 15.7884 4.88584 15.3711C3.93318 14.9682 3.07768 14.3914 2.34314 13.6569C1.60859 12.9223 1.0319 12.0668 0.62889 11.1142C0.211621 10.1275 0 9.0797 0 8C0 6.9203 0.211621 5.87247 0.62889 4.88584C1.0318 3.93318 1.60859 3.07768 2.34314 2.34314C3.07768 1.60859 3.93318 1.0319 4.88584 0.62889C5.87257 0.211621 6.9203 0 8 0C9.0797 0 10.1275 0.211621 11.1142 0.62889C12.0668 1.0318 12.9223 1.60859 13.6569 2.34314C14.3914 3.07768 14.9681 3.93318 15.3711 4.88584C15.7885 5.87247 16 6.9203 16 8C16 9.0797 15.7884 10.1275 15.3711 11.1142C14.9682 12.0668 14.3914 12.9223 13.6569 13.6569C12.9223 14.3914 12.0668 14.9681 11.1142 15.3711C10.1275 15.7885 9.0797 16 8 16ZM8 1.19479C7.08109 1.19479 6.18985 1.37465 5.35133 1.72934C4.541 2.07209 3.81317 2.56283 3.18805 3.18795C2.56293 3.81306 2.07209 4.5409 1.72945 5.35122C1.37475 6.18985 1.19489 7.08098 1.19489 7.9999C1.19489 8.91881 1.37475 9.81005 1.72945 10.6486C2.07219 11.4589 2.56293 12.1867 3.18805 12.8118C3.81327 13.4371 4.541 13.9278 5.35133 14.2706C6.18995 14.6252 7.08109 14.8051 8 14.8051C8.91891 14.8051 9.81015 14.6252 10.6487 14.2706C11.459 13.9278 12.1868 13.4371 12.8119 12.8118C13.4372 12.1867 13.9279 11.4589 14.2706 10.6486C14.6252 9.80994 14.8051 8.91881 14.8051 7.9999C14.8051 7.08098 14.6252 6.18974 14.2706 5.35122C13.9278 4.5409 13.4371 3.81306 12.8119 3.18795C12.1868 2.56283 11.459 2.07198 10.6487 1.72934C9.81005 1.37465 8.91891 1.19479 8 1.19479Z" fill="black"/>
