                    <path d="M8.75792 5.26027C9.34153 5.22159 9.78332 4.71723 9.74465 4.13362C9.70597 3.55001 9.2016 3.10821 8.61799 3.14689C8.03438 3.18556 7.59259 3.68993 7.63126 4.27354C7.66994 4.85715 8.17431 5.29895 8.75792 5.26027Z" fill="black"/>
                    </g>
                    <defs>
                    <clipPath id="clip0_8900_4078">
                    <rect width="16" height="16" fill="white"/>
                    </clipPath>
                    </defs>
                </svg>
              </div>
            </button>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}


    {%- comment -%}══════════════════ COLLECTION DROPDOWN + PRODUCT GRID ══════════════════{%- endcomment -%}
    <div class="bundle-colors">
      <p class="bundle-colors__heading">{{ color_heading }}</p>

      <div class="bundle-colors__filter js-collection-trigger" role="button" tabindex="0" aria-expanded="false" aria-haspopup="listbox">
        <span class="bundle-colors__filter-label js-active-coll-label">
          {%- if block.settings.collection_1 != blank -%}
            {{ block.settings.collection_1.title }}
          {%- else -%}
            All Products
          {%- endif -%}
        </span>
        <span class="bundle-colors__filter-sub js-active-coll-count"></span>
        <svg class="bundle-colors__filter-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <div class="bcp-dropdown" id="bcp-dropdown-{{ section.id }}" role="listbox" aria-label="Select a collection" hidden>
        {%- for i in (1..8) -%}
          {%- assign key  = 'collection_' | append: i -%}
          {%- assign coll = block.settings[key] -%}
          {%- if coll != blank -%}
            <button
              class="bcp-dropdown__item{% if i == 1 %} is-active{% endif %}"
              type="button"
              role="option"
              aria-selected="{% if i == 1 %}true{% else %}false{% endif %}"
              data-coll-handle="{{ coll.handle }}"
              data-coll-title="{{ coll.title | escape }}"
            >
              {{ coll.title }}
              <span class="bcp-dropdown__count">({{ coll.products_count }})</span>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="bundle-colors__grid js-color-grid">
        {%- for i in (1..8) -%}
          {%- assign key  = 'collection_' | append: i -%}
          {%- assign coll = block.settings[key] -%}
          {%- if coll != blank -%}
            {%- for prod in coll.products -%}
              {%- assign first_variant = prod.selected_or_first_available_variant -%}
              <button
                class="color-swatch js-color-swatch"
                type="button"
                data-coll-handle="{{ coll.handle }}"
                data-product-id="{{ prod.id }}"
                data-variant-id="{{ first_variant.id }}"
                data-variant-sku="{{ first_variant.sku | escape }}"
                data-variant-title="{{ first_variant.title | escape }}"
                data-product-handle="{{ prod.handle | escape }}"
                data-product-title="{{ prod.title | escape }}"
                data-product-price="{{ first_variant.price | money }}"
                data-product-compare="{{ first_variant.compare_at_price | money }}"
                data-available="{{ first_variant.available }}"
                data-img-src="{{ prod.featured_image | image_url: width: 160 }}"
                data-img-alt="{{ prod.featured_image.alt | default: prod.title | escape }}"
                aria-label="{{ prod.title | escape }}"
                aria-pressed="false"
                title="{{ prod.title | escape }}"
                {% unless i == 1 %}style="display:none"{% endunless %}
              >
                {%- if prod.featured_image -%}
                  <img
                    src="{{ prod.featured_image | image_url: width: 160 }}"
                    alt="{{ prod.featured_image.alt | default: prod.title | escape }}"
                    width="160"
                    height="160"
                    loading="lazy"
                  >
                {%- else -%}
                  <span class="color-swatch__fallback">{{ prod.title | truncate: 3, '' }}</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>


    {%- comment -%}══════════════════ SELECTED TRAY ══════════════════{%- endcomment -%}
    <div class="bundle-selected">
      <p class="bundle-selected__heading">{{ selected_heading }}</p>
      <div class="bundle-selected__tray js-selected-tray" data-variant-id="{{ product.selected_or_first_available_variant.id }}"></div>
    </div>

  </div>
</section>


{%- comment -%}════════════════════════════════════════════════
  ATC FORM WRAPPER
  Mirrors the hooks from buy-buttons.liquid so BundleCollectionPicker
  can find form[data-type="add-to-cart-form"] and .js-bundle-submit.
  The form is scoped to section.id, matching the data-section-id
  on the <section> above.
════════════════════════════════════════════════{%- endcomment -%}

{%- liquid
  comment
    Pick the "parent" product for the Shopify form tag.
    Prefer product_1; fall back to product_2.
    If neither is set we cannot render a valid form — show nothing.
  endcomment
  assign form_product = product_1
  if form_product == blank
    assign form_product = product_2
  endif
-%}


{%- comment -%}════════════════════════════════════════════════
  STYLES  (bundle-section styles + dropdown styles)
  These are the same as in bundle-collection-picker.liquid.
  If both snippets are used on the same page the rules will
  simply be declared twice — harmless duplication.
════════════════════════════════════════════════{%- endcomment -%}
{% style %}

/* ── Bundle section base ── */
.bundle-section {
  --bundle-accent: #c94b7b;
  --bundle-accent-light: #fde8f0;
  --bundle-border: #e5e5e5;
  --bundle-text: #1a1a1a;
  --bundle-muted: #777;
  --bundle-radius: 10px;
  --bundle-radius-sm: 6px;
  --bundle-transition: 0.18s ease;
  font-family: inherit;
  color: var(--bundle-text);
  max-width: 100%;
  padding: 0 0 24px;
}

.bundle-section__inner {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

/* Tiers */
.bundle-tiers__heading { margin: 0 0 28px; }
span.bundle-tiers__heading-label { font-weight: 600; font-size: 14px; line-height: 20.8px; color: #000; vertical-align: middle; }
.bundle-tiers__heading-count { font-weight: 100; font-size: 14px; line-height: 20.8px; color: #000; vertical-align: middle; }
.bundle-tiers__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }

.bundle-tier {
  position: relative; display: flex; flex-direction: column; align-items: center;
  gap: 8px; padding: 14px 20px; background: #fff; cursor: pointer;
  transition: all 0.3s ease; text-align: center;
  border: 1px solid #D99CA580;
}
.bundle-tier:hover { border-color: #D99CA5; }
.bundle-tier.is-active { border-color: #D99CA5; box-shadow: 0px 4px 0px 0px #D99CA5; }

.bundle-tier__badge {
  position: absolute; top: -19px; left: 50%; transform: translateX(-50%);
  background: #D99CA5; color: #fff; padding: 2px 12px; white-space: nowrap;
  font-size: 12px; line-height: 14.4px; letter-spacing: 0; text-align: center;
}
button.bundle-tier.is-active .bundle-tier__badge { background: #7C0732; }

.bundle-tier__label { color: #000; font-weight: 600; font-size: 14px; line-height: 21px; text-align: center; max-width: 100px; }
.bundle-tier__pricing { display: flex; align-items: center; gap: 5px; margin-top: 4px; }
.bundle-tier__price { font-size: 14px; font-weight: 700; color: #1a1a1a; }
.bundle-tier__compare { font-size: 12px; color: #777; text-decoration: line-through; }

/* Child products */
.bundle-products__heading { margin: 0 0 8px; font-weight: 600; font-size: 14px; line-height: 20.8px; color: #000; }
.bundle-products__selected-name { font-weight: 200; font-size: 14px; line-height: 20.8px; color: #000; }
.bundle-products__grid { display: flex; gap: 10px; }

.bundle-product {
  position: relative; display: flex; align-items: center; gap: 10px;
  padding: 14px 10px; background: #fff; cursor: pointer; text-align: left;
  transition: all 0.3s ease; width: 100%; max-width: calc(50% - 5px);
  border: 1px solid #D99CA580;
}
.bundle-product:hover { border-color: #D99CA5; }
.bundle-product.is-active { box-shadow: 0px 4px 0px 0px #D99CA5; border-color: #D99CA5; }

.bundle-product__img-wrap { width: 46px; flex-shrink: 0; overflow: hidden; }
.bundle-product__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
.bundle-product__info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; }
.bundle-product__name { font-weight: 600; font-size: 14px; line-height: 16.4px; color: #000; padding-right: 20px; }
.bundle-product__desc { font-weight: 400; font-size: 14px; line-height: 18.8px; color: #000; }
.bundle-product__info-btn { position: absolute; top: 12px; right: 4px; cursor: pointer; padding: 0; z-index: 2; width: 16px; height: 16px; transition: all 0.3s ease; }
.bundle-product__info-btn svg { width: 100%; height: 100%; display: block; }
.bundle-product__info-btn:hover { transform: scale(1.1) !important; }

/* Collection filter */
.bundle-colors__heading { margin: 0 0 8px; font-weight: 600; font-size: 14px; line-height: 20.8px; color: #000; }
.bundle-colors__filter { display: flex; align-items: center; gap: 10px; padding: 12px 22px; margin-bottom: 12px; cursor: pointer; background: #fff; border: 1px solid #D99CA580; }
.bundle-colors__filter:focus-visible { outline: 2px solid #D99CA5; outline-offset: 2px; }
.bundle-colors__filter-label { font-weight: 600; font-size: 14px; line-height: 20.4px; color: #000; text-align: center; vertical-align: middle; }
.bundle-colors__filter-sub { color: #000; flex: 1; font-weight: 400; font-size: 14px; }
.bundle-colors__filter-chevron { color: #2D444A; }

/* Dropdown */
.bcp-dropdown { position: relative; z-index: 100; background: #fff; border: 1px solid #D99CA5; box-shadow: 0 4px 16px rgba(0,0,0,0.10); margin-bottom: 12px; display: flex; flex-direction: column; top: -13px; }
.bcp-dropdown[hidden] { display: none; }
.bcp-dropdown__item { display: flex; align-items: center; justify-content: space-between; gap: 8px; width: 100%; padding: 10px 18px; background: transparent; border: none; border-bottom: 1px solid #f0e8eb; cursor: pointer; font-size: 14px; font-weight: 400; color: #000; text-align: left; transition: background 0.15s ease; }
.bcp-dropdown__item:last-child { border-bottom: none; }
.bcp-dropdown__item:hover { background: #fde8f0; }
.bcp-dropdown__item.is-active { background: #fde8f0; font-weight: 600; }
.bcp-dropdown__count { font-size: 12px; font-weight: 400; color: #999; margin-left: auto; }

/* Color grid */
.bundle-colors__grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; max-height: 482px; overflow-y: scroll; padding:4px 16px 4px 4px; scrollbar-width: thin; scrollbar-color: #D99CA5 transparent; }
.bundle-colors__grid::-webkit-scrollbar { width: 4px; }
.bundle-colors__grid::-webkit-scrollbar-track { background: transparent; }
.bundle-colors__grid::-webkit-scrollbar-thumb { background: #D99CA5; border-radius: 10px; }

/* Swatches */
.color-swatch {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    border: 1px solid var(--mid-pink-50, #D99CA580);
    width: 100%;
    height: max-content;
}


.color-swatch img { width: 100%; height: 100%; object-fit: cover; display: block; }
.color-swatch__fallback { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; font-size: 10px; font-weight: 700; color: #777; }
.color-swatch:hover { border-color: #c94b7b; transform: scale(1.05); }
.color-swatch.is-selected { border-color: #D99CA5; box-shadow: 0px 4px 0px 0px #D99CA5 !important; background: #fff !important; }
.color-swatch::after { content: attr(title); position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%); background: #1a1a1a; color: #fff; font-size: 10px; white-space: nowrap; padding: 3px 8px; border-radius: 3px; pointer-events: none; opacity: 0; transition: opacity 0.15s ease; z-index: 10; }
.color-swatch:hover::after { opacity: 1; }

/* Selected tray */
.bundle-selected__heading { margin: 0 0 8px; font-weight: 600; font-size: 14px; line-height: 20.8px; color: #000; }
.bundle-selected__tray { display: flex; gap: 8px; flex-wrap: wrap; }
.selected-slot { max-width: calc(16.66% - 6.66px); width: 100%; aspect-ratio: 1; overflow: hidden; background: transparent; position: relative; cursor: default; transition: all 0.3s ease; border: 1px solid #D99CA580; }
.selected-slot.is-filled { border-color: #D99CA5; box-shadow: 0px 4px 0px 0px #D99CA5; }
.selected-slot img { width: 100%; height: 100%; object-fit: cover; display: block; }
.selected-slot__remove { position: absolute; top: 3px; right: 3px; width: 18px; height: 18px; border-radius: 50%; background: rgba(0,0,0,0.5); border: none; color: #fff; font-size: 11px; line-height: normal; box-sizing: border-box; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.18s ease; padding: 0; }
.selected-slot:hover .selected-slot__remove { opacity: 1; }
.selected-slot__placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.selected-slot__placeholder svg { color: #ccc; }
.selected-slot__label { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.55); color: #fff; font-size: 8px; line-height: 1.2; padding: 2px 4px; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Tooltip */
.bundle-tooltip { position: fixed; z-index: 9999; max-width: 260px; background: #1a1a1a; color: #fff; font-size: 12px; line-height: 1.5; padding: 10px 14px; border-radius: 6px; pointer-events: none; opacity: 0; transition: opacity 0.15s ease; }
.bundle-tooltip.is-visible { opacity: 1; }

/* ATC button */
.bundle-atc-form { margin-top: 4px; }
.bundle-atc-btn { width: 100%; }

/* Responsive */
@media screen and (max-width: 768px) {
  .bundle-section__inner { gap: 20px; }
  .bundle-tiers__heading { margin: 0 0 24px; }
  .bundle-tier { gap: 6px; padding: 11px 14px; }
  .bundle-tier__label { font-size: 12px; line-height: 15.6px; }
  .bundle-tier__badge { top: -19px; }
  .bundle-products__grid { flex-direction: column !important; }
  .bundle-product { max-width: 100%; padding: 10px; }
  .bundle-colors__filter { padding: 10px 16px; }
  .bundle-colors__filter-label { font-size: 12px; line-height: 16.4px; }
  .bundle-colors__filter-sub { font-size: 12px; }
  .bundle-colors__grid { grid-template-columns: repeat(4, 1fr); max-height: 352px; }
  .selected-slot { max-width: calc(25% - 6px); }
}

