{% comment %}
  ============================================================
  collection-bundle.liquid  (SNIPPET)
  ============================================================
  Renders the full bundle color-picker widget.

  USAGE
  ──────────────────────────────────────────────────────────
  {% render 'collection-bundle',
    block:     block,
    section:   section,
    product_1: block.settings.product_1,
    product_2: block.settings.product_2
  %}

  PARAMETERS
  ──────────────────────────────────────────────────────────
  block      — the calling block (for block.settings.*)
  section    — the parent section (for section.id scoping)
  product_1  — first child product (Shopify product object)
  product_2  — second child product (Shopify product object)

  Previously these came from:
    product.metafields.custom.landing_page_products.value
  They are now passed in directly from block.settings so no
  metafields or featured-product section are required.

  All collection picker, tier, swatch, tray, and ATC logic
  is identical to the original bundle-collection-picker.
  ============================================================
{% endcomment %}

{%- liquid
  comment
    Build child_products array from the two passed-in products.
    Filter out blank values so the loop is clean.
  endcomment
  assign child_products = ''
-%}

{%- comment -%}
  Liquid doesn't support dynamic arrays, so we iterate
  an inline comma-separated count and branch on index.
  We use a simple forloop over a 2-item range and pick
  the right variable each time.
{%- endcomment -%}

{%- liquid
  assign cp_list_str = ''
  if product_1 != blank
    if cp_list_str == ''
      assign cp_list_str = '1'
    else
      assign cp_list_str = cp_list_str | append: ',1'
    endif
  endif
  if product_2 != blank
    if cp_list_str == ''
      assign cp_list_str = '2'
    else
      assign cp_list_str = cp_list_str | append: ',2'
    endif
  endif
  assign cp_items = cp_list_str | split: ','
-%}

{%- comment -%} Pull tier / label settings from block or section {%- endcomment -%}
{%- liquid
  assign tier_2_price   = block.settings.tier_2_price   | default: section.settings.tier_2_price
  assign tier_4_price   = block.settings.tier_4_price   | default: section.settings.tier_4_price
  assign tier_6_price   = block.settings.tier_6_price   | default: section.settings.tier_6_price
  assign tier_2_compare = block.settings.tier_2_compare_price | default: section.settings.tier_2_compare_price
  assign tier_4_compare = block.settings.tier_4_compare_price | default: section.settings.tier_4_compare_price
  assign tier_6_compare = block.settings.tier_6_compare_price | default: section.settings.tier_6_compare_price
  assign tier_2_label   = block.settings.tier_2_label | default: section.settings.tier_2_label | default: '2 Products'
  assign tier_4_label   = block.settings.tier_4_label | default: section.settings.tier_4_label | default: '4 Products'
  assign tier_6_label   = block.settings.tier_6_label | default: section.settings.tier_6_label | default: '6 Products'
  assign bundle_label   = block.settings.bundle_label  | default: section.settings.bundle_label  | default: 'Select Your Bundle:'
  assign product_heading = block.settings.product_heading | default: section.settings.product_heading | default: 'Choose'
  assign color_heading   = block.settings.color_heading   | default: section.settings.color_heading   | default: 'Select Products'
  assign selected_heading = block.settings.selected_heading | default: section.settings.selected_heading | default: 'Selected Products'
-%}

<section
  class="bundle-section"
  id="bundle-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="bundle-section__inner">

    {%- comment -%}══════════════════ TIER SELECTOR ══════════════════{%- endcomment -%}
    <div class="bundle-tiers">
      <p class="bundle-tiers__heading">
        <span class="bundle-tiers__heading-label">{{ bundle_label }}</span>
        <span class="bundle-tiers__heading-count js-tier-count">
          {{- block.settings.tier_2_colors | default: section.settings.tier_2_colors | default: 2 -}} Colors
        </span>
      </p>

      <div class="bundle-tiers__grid">
        {%- assign tiers = '2,4,6' | split: ',' -%}
        {%- for tier in tiers -%}
          {%- liquid
            case tier
              when '2'
                assign t_label   = tier_2_label
                assign t_price   = tier_2_price
                assign t_compare = tier_2_compare
                assign t_qty     = block.settings.tier_2_colors | default: section.settings.tier_2_colors | default: 2
                assign t_badge   = block.settings.tier_2_badge  | default: section.settings.tier_2_badge
                assign t_active  = true
              when '4'
                assign t_label   = tier_4_label
                assign t_price   = tier_4_price
                assign t_compare = tier_4_compare
                assign t_qty     = block.settings.tier_4_colors | default: section.settings.tier_4_colors | default: 4
                assign t_badge   = block.settings.tier_4_badge  | default: section.settings.tier_4_badge
                assign t_active  = false
              when '6'
                assign t_label   = tier_6_label
                assign t_price   = tier_6_price
                assign t_compare = tier_6_compare
                assign t_qty     = block.settings.tier_6_colors | default: section.settings.tier_6_colors | default: 6
                assign t_badge   = block.settings.tier_6_badge  | default: section.settings.tier_6_badge
                assign t_active  = false
            endcase
          -%}
          <button
            class="bundle-tier{% if t_active %} is-active{% endif %}"
            data-tier="{{ t_qty }}"
            data-price="{{ t_price }}"
            data-compare-price="{{ t_compare }}"
            data-default-price="{{ t_price }}"
            type="button"
            aria-pressed="{% if t_active %}true{% else %}false{% endif %}"
          >
            {%- if t_badge != blank -%}
              <span class="bundle-tier__badge">{{ t_badge }}</span>
            {%- endif -%}
            <span class="bundle-tier__label">{{ t_label }}</span>
            <span class="bundle-tier__pricing">
              <span class="bundle-tier__price">{{ t_price }}</span>
              {%- if t_compare != blank -%}
                <s class="bundle-tier__compare">{{ t_compare }}</s>
              {%- endif -%}
            </span>
          </button>
        {%- endfor -%}
      </div>
    </div>


    {%- comment -%}══════════════════ CHILD PRODUCT SELECTOR ══════════════════
      Previously read from: product.metafields.custom.landing_page_products.value
      Now reads from:       product_1 and product_2 render parameters
    ══════════════════{%- endcomment -%}

    {%- if product_1 != blank or product_2 != blank -%}
      <div class="bundle-products">
        <p class="bundle-products__heading">
          {{ product_heading }}
          <span class="bundle-products__selected-name js-selected-product-name">
            {%- if product_1 != blank -%}{{ product_1.title }}{%- elsif product_2 != blank -%}{{ product_2.title }}{%- endif -%}
          </span>
        </p>

        <div class="bundle-products__grid">
          {%- comment -%} Product 1 {%- endcomment -%}
          {%- if product_1 != blank -%}
            {%- assign cp = product_1 -%}
            <button
              class="bundle-product is-active"
              data-product-id="{{ cp.selected_or_first_available_variant.id }}"
              data-variant-qty="1"
              data-product-handle="{{ cp.handle }}"
              data-product-title="{{ cp.title | escape }}"
              data-price="{{ cp.price | money }}"
              data-compare-price="{{ cp.compare_at_price | money }}"
              type="button"
              aria-pressed="true"
            >
              <div class="bundle-product__img-wrap">
                {%- if cp.featured_image -%}
                  {{- cp.featured_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: cp.title -}}
                {%- endif -%}
              </div>
              <div class="bundle-product__info">
                <span class="bundle-product__name">{{ cp.title }}</span>
                {%- if cp.description != blank -%}
                  <span class="bundle-product__desc">{{ cp.description | strip_html | truncate: 60 }}</span>
                {%- endif -%}
              </div>
              <div
                class="bundle-product__info-btn js-open-popup"
                data-popup-index="1"
                aria-label="More info about {{ cp.title }}"
                title="{{ cp.title | escape }}"
                data-product-title="{{ cp.title | escape }}"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <g clip-path="url(#clip0_8900_4078)">
                    <path d="M8 16C6.9203 16 5.87247 15.7884 4.88584 15.3711C3.93318 14.9682 3.07768 14.3914 2.34314 13.6569C1.60859 12.9223 1.0319 12.0668 0.62889 11.1142C0.211621 10.1275 0 9.0797 0 8C0 6.9203 0.211621 5.87247 0.62889 4.88584C1.0318 3.93318 1.60859 3.07768 2.34314 2.34314C3.07768 1.60859 3.93318 1.0319 4.88584 0.62889C5.87257 0.211621 6.9203 0 8 0C9.0797 0 10.1275 0.211621 11.1142 0.62889C12.0668 1.0318 12.9223 1.60859 13.6569 2.34314C14.3914 3.07768 14.9681 3.93318 15.3711 4.88584C15.7885 5.87247 16 6.9203 16 8C16 9.0797 15.7884 10.1275 15.3711 11.1142C14.9682 12.0668 14.3914 12.9223 13.6569 13.6569C12.9223 14.3914 12.0668 14.9681 11.1142 15.3711C10.1275 15.7885 9.0797 16 8 16ZM8 1.19479C7.08109 1.19479 6.18985 1.37465 5.35133 1.72934C4.541 2.07209 3.81317 2.56283 3.18805 3.18795C2.56293 3.81306 2.07209 4.5409 1.72945 5.35122C1.37475 6.18985 1.19489 7.08098 1.19489 7.9999C1.19489 8.91881 1.37475 9.81005 1.72945 10.6486C2.07219 11.4589 2.56293 12.1867 3.18805 12.8118C3.81327 13.4371 4.541 13.9278 5.35133 14.2706C6.18995 14.6252 7.08109 14.8051 8 14.8051C8.91891 14.8051 9.81015 14.6252 10.6487 14.2706C11.459 13.9278 12.1868 13.4371 12.8119 12.8118C13.4372 12.1867 13.9279 11.4589 14.2706 10.6486C14.6252 9.80994 14.8051 8.91881 14.8051 7.9999C14.8051 7.08098 14.6252 6.18974 14.2706 5.35122C13.9278 4.5409 13.4371 3.81306 12.8119 3.18795C12.1868 2.56283 11.459 2.07198 10.6487 1.72934C9.81005 1.37465 8.91891 1.19479 8 1.19479Z" fill="black"/>
