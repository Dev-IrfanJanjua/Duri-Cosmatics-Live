<script>
document.addEventListener('DOMContentLoaded', () => {

  function updateTierCount() {
    const activeTier = document.querySelector('.bundle-tier.is-active');
    const displayEl  = document.querySelector('.js-tier-count');

    if (!activeTier || !displayEl) return;

    const tierValue = activeTier.dataset.tier;

    displayEl.textContent = `${tierValue} Colors`;
  }

  // Run on load
  updateTierCount();

  // Listen for tier clicks
  document.querySelectorAll('.bundle-tier').forEach(btn => {
    btn.addEventListener('click', () => {
      // Wait for your existing logic to update "is-active"
      setTimeout(updateTierCount, 50);
    });
  });

});
</script>