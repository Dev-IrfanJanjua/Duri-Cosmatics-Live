{% style %}

.bundle-popup {
    position: fixed;
    inset: 0;
    z-index: 999;
    width: 100%;
}

.bundle-popup[hidden] {
  display: none;
}

.bundle-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    width: 100%;
    height: 100%;
    display: block !important;
}

.bundle-popup__content {
    position: fixed;
    max-width: 820px;
    margin: auto;
    background: #fff;
    z-index: 2;
    transform: translate(0, 0);
    opacity: 0;
    transition: all 0.3s ease;
    width: 100%;
    top: 50%;
    left: 50%;
}

.bundle-popup:not([hidden]) .bundle-popup__content {
  transform: translate(-50%, -50%);
  opacity: 1;
}

.bundle-popup__close {
    position: absolute;
    top: 20px;
    right: 20px;
    cursor: pointer;
    width: 20px;
    height: 20px;
}

.bundle-popup__close svg{
    display: block;
    width: 100%;
    height: 100%;
}

.bundle-popup__inner_img {
    max-width: 50%;
    width: 100%;
    height: 100%;
}

.bundle-popup__inner_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.bundle-popup__inner {
    display: flex;
    align-items: stretch;
}

.bundle-popup__inner_content {
    max-width: 50%;
    width: 100%;
    padding: 50px 30px 30px;
    max-height: 510px;
    overflow-y: auto;
    scrollbar-width: none;
}

h3.bundle-popup__title {
    font-family: PP Mori;
    font-weight: 600;
    font-size: 20px;
    line-height: 26px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
    margin: 0 0 12px;
}

p.bundle-popup__desc {
    font-family: PP Mori;
    font-weight: 400;
    font-style: Regular;
    font-size: 14px;
    leading-trim: NONE;
    line-height: 21px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
}

.bundle-accordion {
    border: 1px solid #7BA69D66;
}

.bundle-accordion__item {
    /* padding: 12px; */
    border-bottom: 1px solid #7BA69D66;
    transition: all 0.3s ease;
}

.bundle-accordion__item:last-child{
    border: none;
}

.bundle-accordion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3px;
    padding: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
}

span.bundle-accordion__header_text {
    font-family: PP Mori;
    font-weight: 600;
    font-style: SemiBold;
    font-size: 14px;
    leading-trim: NONE;
    line-height: 21px;
    letter-spacing: 0%;
    vertical-align: middle;
    color: #000;
    margin: 0;
}

.bundle-accordion__item.is-active {
    padding-bottom: 12px;
}

.bundle-accordion__item.is-active .bundle-accordion__header {
    padding-bottom: 8px;
}

.bundle-accordion__content {
    max-height: 0;
    overflow: hidden;
    transition: all 0.35s ease;
    font-family: PP Mori;
    font-weight: 400;
    font-style: Regular;
    font-size: 12px;
    leading-trim: NONE;
    line-height: 18px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
    padding: 0 26px 0 12px;
}

.bundle-accordion__icon {
    display: block;
    transition: transform 0.35s ease;
    width: 11px;
    height: 6px;
}

span.bundle-accordion__icon svg {
    width: 100%;
    height: 100%;
    display: block;
}

.bundle-accordion__item.is-active .bundle-accordion__icon {
  transform: rotate(180deg);
}

@media screen and (max-width: 768px){

.bundle-popup__inner {
    flex-direction: column;
}

.bundle-popup__inner_img {
    max-width: 100%;
    align-self: center;
    aspect-ratio: 3/2;
    object-position: center;
}

.bundle-popup__inner_content {
    max-width: 100%;
    width: 100%;
    padding: 50px 16px 30px;
}

.bundle-popup__content {
    height: 100%;
    overflow-y: auto;
}

}


{% endstyle %}


