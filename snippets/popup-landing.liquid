{% comment %} ============= Popup js start ====================== {% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function () {

  const popups = document.querySelectorAll('.js-bundle-popup');

  // OPEN POPUP
  document.querySelectorAll('.js-open-popup').forEach(btn => {
    btn.addEventListener('click', function () {

      const index = this.dataset.popupIndex;

      const popup = document.querySelector(
        `.js-bundle-popup[data-popup-index="${index}"]`
      );

      if (!popup) return;

      popup.removeAttribute('hidden');
      document.body.classList.add('popup-open');
    });
  });

  // CLOSE POPUP
  document.querySelectorAll('.js-popup-close').forEach(el => {
    el.addEventListener('click', function () {
      const popup = this.closest('.js-bundle-popup');
      popup.setAttribute('hidden', true);
      document.body.classList.remove('popup-open');
    });
  });

});
</script>

{% comment %} ============= Popup js end ====================== {% endcomment %}

{% comment %} ============= accordian js start ===================== {% endcomment %}

<script>
if (!window.bundleAccordionInitialized) {
  window.bundleAccordionInitialized = true;

  // handle accordion toggle
  document.addEventListener('click', function (e) {
    const header = e.target.closest('.bundle-accordion__header');
    if (!header) return;

    const accordion = header.closest('.bundle-accordion');
    const item = header.closest('.bundle-accordion__item');
    const content = item.querySelector('.bundle-accordion__content');
    const isActive = item.classList.contains('is-active');

    // close all items in this accordion
    accordion.querySelectorAll('.bundle-accordion__item').forEach(function (otherItem) {
      otherItem.classList.remove('is-active');
      otherItem.querySelector('.bundle-accordion__content').style.maxHeight = '0px';
    });

    // toggle clicked item
    if (!isActive) {
      item.classList.add('is-active');
      content.style.maxHeight = content.scrollHeight + 'px';
    }
  });

  // handle popup open
  document.querySelectorAll('.js-open-popup').forEach(btn => {
    btn.addEventListener('click', function () {
      const index = this.dataset.popupIndex;
      const popup = document.querySelector(`.js-bundle-popup[data-popup-index="${index}"]`);
      if (!popup) return;

      popup.removeAttribute('hidden');

      // open the first accordion item if none active
      const firstItem = popup.querySelector('.bundle-accordion__item');
      if (firstItem && !popup.querySelector('.bundle-accordion__item.is-active')) {
        firstItem.classList.add('is-active');
        const content = firstItem.querySelector('.bundle-accordion__content');
        content.style.maxHeight = content.scrollHeight + 'px';
      }

      // if already has is-active from Liquid forloop, ensure content visible
      popup.querySelectorAll('.bundle-accordion__item.is-active').forEach(item => {
        const content = item.querySelector('.bundle-accordion__content');
        content.style.maxHeight = content.scrollHeight + 'px';
      });

      document.body.classList.add('popup-open');
    });
  });
}
</script>

{% comment %} ============= accordian js end ===================== {% endcomment %}