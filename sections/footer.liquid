.new-links-my {
    position: relative;
    display: inline-block !important;
    text-decoration: none;
    color: #000 !important;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px !important;
    line-height: 18.2px;
    letter-spacing: 0px;
    vertical-align: middle;
    padding: 0;
}

.new-links-my::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  height: 1px; /* line thickness */
  width: 100%;
  background-color: currentColor; /* uses text color */
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease-in-out;
}

.new-links-my:hover::after {
  transform: scaleX(1);
}



span.new-links-my {
  position: relative;
  display: inline-block;  
  text-decoration: none;
  color: #6E6E6E;
  padding-bottom: 0px; /* space for line */
} 

span.new-links-my::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  height: 1px; /* line thickness */
  width: 100%;
  background-color: #6E6E6E; /* uses text color */
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease-in-out;
}

span.new-links-my:hover::after {
  transform: scaleX(1);
}



.header__menu-item.list-menu__item.link.link--text.focus-inset {
  position: relative;
