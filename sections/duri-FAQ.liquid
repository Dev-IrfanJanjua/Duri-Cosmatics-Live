<style> 
  .custom-faq-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-color }};
  }

  .custom-faq-section-{{ section.id }} .custom-faq-heading {
    font-family: 'PP Mori';
    font-size: 46px;
    font-weight: 600;
    color: #000;
    text-align: center;
    margin: 0 0 30px;
  }

  .custom-faq-section-{{ section.id }} .custom-faq-item {
    text-align: left;
    border-top: 1px solid #7BA69D66;
    transition: all 0.3s ease;
  }
  .custom-faq-section-{{ section.id }} .custom-faq-item.active{
    padding-bottom: 24px;
  }

  .custom-faq-section-{{ section.id }} .custom-faq-item.active .custom-faq-question {
    padding-bottom: 12px;
}
  
  .custom-faq-section-{{ section.id }} .custom-faq-question {
    cursor: pointer;
    font-family: 'PP Mori';
    font-size: 20px;
    font-weight: 600;
    color: #000;
    padding: 24px 26px;
    position: relative;
    line-height: 28px;
    transition: all 0.3s ease;
    display: flex;
    gap: 10px;
    justify-content: space-between;
    align-items: center;
  }

  .custom-faq-section-{{ section.id }} .custom-faq-item.custom-faq-item_first {
    border: none;
}

  {% comment %} .custom-faq-section-{{ section.id }} .custom-faq-question:hover {
    color: #D077FF;
  }  {% endcomment %}

  .custom-faq-section-{{ section.id }} .custom-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, padding 0.3s ease;
  color: #000;
  font-size: 14px;
  line-height: 21px;
  padding: 0 26px; /* collapsed: no bottom padding */
}

.custom-faq-wrapper {
    text-align: center;
}

  .custom-faq-section-{{ section.id }} .custom-faq-toggle {
    font-size: 20px;
    transition: transform 0.3s ease;
  }

  .custom-faq-section-{{ section.id }} .custom-faq-item.active .custom-faq-toggle {
    transform: rotate(180deg);
  }

  .custom-faq-section-{{ section.id }} .custom-faq-button {
    display: inline-block;
    margin-top: 40px;
    background-color: {{ section.settings.btn_color }};
    color: white;
    padding: 14px 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 600;
    font-size: 16px;
    line-height: 20px;
    letter-spacing: 0%;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
  }

  .custom-faq-section-{{ section.id }} .custom-faq-button:hover {
    transform: translateY(-3px);
  }

 
.custom-faq-question p {
    margin: 0;
}

  @media screen and (max-width: 768px) {
    .custom-faq-section-{{ section.id }} {
      padding-top: {{ section.settings.mbl_padding_top }}px;
      padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
    }
    .custom-faq-section-template--21723829666034__duri_faq_gxC3br .custom-faq-heading {
        font-family: 'PP Mori';
        font-size: 28px;
        font-weight: 600;
        line-height: 36.4px;
        color: #000;
        text-align: center;
        margin: 0 0 24px;
    }
    .custom-faq-section-template--21723829666034__duri_faq_gxC3br .custom-faq-button {
        margin-top: 24px;
    }
    .custom-faq-section-template--21723829666034__duri_faq_gxC3br .custom-faq-item.active {
        padding-bottom: 12px;
    }
    .custom-faq-section-template--21723829666034__duri_faq_gxC3br .custom-faq-item.active .custom-faq-question {
        padding-bottom: 8px;
    }
    .custom-faq-section-{{ section.id }} .custom-faq-question {
        font-size: 14px;
        padding: 12px 16px;
        line-height: 19.6px;
    }
    .custom-faq-section-{{ section.id }} .custom-faq-answer {
        padding-left: 16px;
        max-width: 305px;
    }
  }
</style>

<section class="custom-faq-section-{{ section.id }}">
  <div class="page-width">
    <div class="custom-faq-wrapper">
      <h2 class="custom-faq-heading">{{ section.settings.heading }}</h2>
    
      <div class="custom-faq-container">
        {% for block in section.blocks %}
          <div class="custom-faq-item {% if forloop.first %}custom-faq-item_first{% endif %}">
            <div class="custom-faq-question">
              <p class="faq-quest">{{ block.settings.question }}</p>
              <span class="custom-faq-toggle">{% render 'myfaq-svg' %}</span>
            </div>
            <div class="custom-faq-answer">
              {{ block.settings.answer }}
            </div>
          </div>
        {% endfor %}
      </div>
    
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="custom-faq-button">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% comment %} <script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqItems = document.querySelectorAll('.custom-faq-section-{{ section.id }} .custom-faq-item');
    faqItems.forEach(item => {
      item.querySelector('.custom-faq-question').addEventListener('click', () => {
        item.classList.toggle('active');
      });
    });
  });
</script>  {% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqItems = document.querySelectorAll('.custom-faq-section-{{ section.id }} .custom-faq-item');

    faqItems.forEach(item => {
      const question = item.querySelector('.custom-faq-question');
      const answer = item.querySelector('.custom-faq-answer');

      question.addEventListener('click', () => {
        const isActive = item.classList.contains('active');

        // Close all other items (optional)
        faqItems.forEach(i => {
          i.classList.remove('active');
          i.querySelector('.custom-faq-answer').style.maxHeight = null;
        });

        // Toggle the clicked one
        if (!isActive) {
          item.classList.add('active');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        } else {
          item.classList.remove('active');
          answer.style.maxHeight = null;
        }
      });
    });
  });
</script>




{% schema %}
{
  "name": "Duri faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back-color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Color",
      "default": "#7C0732"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Duri faq"
    }
  ]
}
{% endschema %}
