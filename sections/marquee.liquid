{% style %}
.sec-{{ section.id }} {
    padding-block: {{ section.settings.padding_block }}px;
    overflow: hidden;
    background-color: {{ section.settings.background_color }};
    {% if section.settings.border %}
        border-top: 1px solid {{ section.settings.border_color }};
        border-bottom: 1px solid {{ section.settings.border_color }};
    {% endif %}
}

.csym-track-mf {
    display: flex;
      animation: scroll-left 30s linear infinite; /* fast */
    width: max-content;
    will-change: transform; /* Helps with smooth rendering */
}

.cysm-feature-icon-item-mf {
    display: flex;
    align-items: center;
    margin-right: 24px;
    white-space: nowrap;
}

.cysm-feature-icon-item-mf img {
    min-width: 60px;
    height: 60px;
    flex-shrink: 0;
    margin-right: 24px;
    width: 60px;
}

.cysm-feature-icon-item-mf span {
    color: #000;
    font-family: Helvetica !important;
    font-weight: 400;
    font-size: 16px;
    line-height: 15.6px;
    letter-spacing: 0.65px;
    vertical-align: middle;
    text-transform: uppercase;
}


/* Keyframes for continuous scroll */
@keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

@media screen and (max-width: 768px){
    .sec-{{ section.id }} {
        padding-block: {{ section.settings.padding_block_mob }}px;
    }
    .cysm-feature-icon-item-mf {
        margin-right: 20px;
    }

    .cysm-feature-icon-item-mf span {
        font-size: 14px;
        line-height: 18.2px;
    }

}

{% endstyle %}

{% if section.settings.hide %}
<style>
    @media (min-width: 768px) {
        .sec-{{ section.id }} {
            display: none;
        }
    }
</style>
{% endif %}

<div class="csym-container-mf sec-{{ section.id }}" style="background-color: {{section.settings.background_color}};">
    <div class="csym-track-mf">
        {% for block in section.blocks %}
            <div class="cysm-feature-icon-item-mf">
                {% if block.settings.icon %}
                    <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.icon.alt }}" width="auto" height="auto" loading="eager" fetchpriority="high">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        <!-- Duplicate the content once for seamless looping -->
        {% for block in section.blocks %}
            <div class="cysm-feature-icon-item-mf">
                {% if block.settings.icon %}
                    <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.icon.alt }}" width="auto" height="auto" loading="eager" fetchpriority="high">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}
    </div>
</div>

{% schema %}
{
    "name": "CSTM Marquee",
    "tag": "section",
    "class": "scrolling-feature-icons",
    "settings": [
        {
            "type": "checkbox",
            "id": "hide",
            "label": "Hide Desktop"
        },
        {
            "type": "checkbox",
            "id": "border",
            "label": "Show Border"
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "Background Color",
            "default": "#E2F1C4",
            "info": "Choose a background color for the section"
        },
        {
            "type": "color",
            "id": "border_color",
            "label": "Border Color"
        },
        {
            "type": "range",
            "id": "padding_block",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Padding Block",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_block_mob",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Padding Block Mobile",
            "default": 0
        }
    ],
    "blocks": [
        {
            "type": "feature",
            "name": "Feature",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "icon",
                    "label": "Icon"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Feature Title",
                    "default": "Feature"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "CSTM Marquee",
            "category": "Custom"
        }
    ]
}
{% endschema %}