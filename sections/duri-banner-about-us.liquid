<style>
.duri-sec-{{ section.id }}-pad {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.back-color }};
  position: relative;
}

/* Hero / Banner */
.duri-hero-bnr-x1 {
  position: relative;
  color: #fff;
  text-align: left;
  padding: 100px 20px;
  background-size: cover;
  background-position: center;
}

.duri-hero-ovl-x1 {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1;
}

.duri-hero-content-x1 {
  position: absolute;
  top: 50%;
  left: 80px;
  transform: translateY(-50%);
  z-index: 2;
}

.duri-stars-wrap-x1 { }

.duri-hero-stars-x1 {
  font-family: Libre Franklin;
  font-weight: 700;
  font-size: 16px;
  line-height: 24px;
  letter-spacing: 0px;
  color: #fff;
}

.duri-hero-heading-x1 {
    letter-spacing: 0px;
    vertical-align: middle;
    margin: 0;
    padding-bottom: 12px;
    color: #FFF;
    font-family: "PP Mori";
    font-size: 46px;
    font-style: normal;
    font-weight: 600;
    line-height: 55px;
    max-width: 546px;
}

.duri-hero-subtxt-x1 p {
  margin: 0;
  padding-bottom: 24px;
  letter-spacing: 0;
}

.duri-btn-main-x1 {
  background-color: #1E4851;
  color: white;
  padding: 14px 50px;
  border: none;
  text-decoration: none;
  font-weight: bold;
  display: inline-block;
  max-width: fit-content;
  transition: background-color 0.4s ease, color 0.4s ease, transform 0.3s ease;
  cursor: pointer;
}
.duri-btn-main-x1:hover {
  background-color: #27606C;
  color: #ffffff;
  transform: translateY(-2px);
}

/* Icons / logos */
.duri-icn-wrap-x1 {
  display: flex;
  gap: 10px;
  padding-top: 12px;
  padding-bottom: 48px;
}
.duri-icn-wrap-x1 { display: none; } /* matches original intent (hidden by default) */

.duri-btn-label-x1 {
  margin: 0;
  letter-spacing: 0px;
  transition: color 0.4s ease;
  color: #FFF;
  text-align: center;
  font-family: "PP Mori";
  font-size: 16px;
  font-style: normal;
  font-weight: 600;
  line-height: 20px;
  text-transform: uppercase;
}

.duri-hero-icns-x1 { }

.duri-logo-wrap-x1 {
  display: flex;
  gap: 32px;
}

.duri-hero-icns-x1 img {
  width: 103px;
  height: 72px;
}

.duri-hero-icns-x1 .duri-icn-lbl-x1 {
  display: flex;
  align-items: center;
  gap: 8px;
  background: white;
  color: black;
  padding: 9px 24.5px;
  font-family: Libre Franklin;
  font-weight: 700;
  font-size: 12px;
  line-height: 100%;
  letter-spacing: 0px;
  text-align: center;
}

/* Images / Video */
.duri-img-x1 {
  width: 100%;
  height: 90vh;
  object-fit: cover;
  display: block;
}
.duri-img-mbl-x1 {
  display: none;
}

/* Variant / CheeseBanner rules */
.duri-Banner-x1 .duri-img-x1 {
  display: block;
}
.duri-Banner-x1 .duri-hero-content-x1 {
  max-width: 785px;
}
.duri-Banner-x1 .duri-stars-wrap-x1 {
  display: none;
}
.duri-stars-wrap-x1 {
  display: none;
}

.duri-Banner-x1 .duri-hero-subtxt-x1 {
  display: block;
}

.duri-hero-subtxt-x1 {
  text-decoration: none;
  color: #FFF;
  font-family: "PP Mori";
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 21px;
  max-width: 546px;
}

.duri-Banner-x1 .duri-btn-main-x1 {
  display: none;
}

.duri-btns-alt-x1 {
  display: none;
}
.duri-Banner-x1 .duri-btns-alt-x1 {
  display: flex;
  gap: 12px;
}

.duri-btn-label4-x1 {
  margin: 0;
  color: var(--Light-100, #FFF);
  text-align: center;
  font-family: "Libre Franklin";
  font-size: 18px;
  font-style: normal;
  font-weight: 700;
  line-height: 32px;
  text-transform: uppercase;
}

/* alternate buttons (hero-button4) */
a.duri-btn-alt-x1 {
  display: flex;
  height: 60px;
  padding: 14px 40px;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: #732727;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: color 0.4s ease, border-color 0.4s ease;
}

/* shiny gradient effect */
a.duri-btn-alt-x1::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.15);
  transition: all 0.5s ease;
  z-index: 0;
}
a.duri-btn-alt-x1:hover::before {
  left: 0;
}
a.duri-btn-alt-x1:hover {
  color: #FFF6E5;
  border-color: #fff;
}

.duri-btn-label4-x1 {
  position: relative;
  z-index: 2;
  margin: 0;
}

/* Country Page variant */
.duri-Banner-country-x1 .duri-btns-alt-x1 {
  display: none;
}
.duri-Banner-country-x1 .duri-hero-subtxt-x1 p {
  margin: 0;
}
.duri-Banner-country-x1 .duri-hero-heading-x1 {
  padding-bottom: 20px;
}

/* heading visibility toggles */
.duri-hero-heading-x1 {
  display: block;
}
.duri-hero-heading-mbl-x1 {
  display: none;
}

/* Mobile */
@media (max-width: 768px) {
  .duri-img-x1 {
    height: 100vh;
    display: none;
  }
  .duri-img-mbl-x1 {
    display: block;
    height: 85vh;
  }
  .duri-hero-content-x1 {
    position: absolute;
    top: unset;
    left: 50%;
    transform: translate(-50%, 0%);
    padding: 0 16px;
    text-align: start;
    align-items: center;
    width: 100%;
    bottom: 0%;
    padding-bottom: 30px;
  }

  .duri-hero-subtxt-x1 p {
    padding-bottom: 16px;
    line-height: 22px;
    text-align: start;
  }

  .duri-hero-heading-x1 {
    padding-top: 12px;
    padding-bottom: 8px;
    letter-spacing: 0px;
    text-align: center;
    color: #FFF;
    font-family: "PP Mori";
    font-size: 38px;
    font-style: normal;
    font-weight: 600;
    line-height: 49.4px;
  }

  .duri-hero-stars-x1 {
    font-size: 14px;
    line-height: 20px;
  }

  .duri-btn-main-x1 {
    padding: 10px 32px;
  }

  .duri-btn-label-x1 {
    font-size: 14px;
    line-height: 20px;
  }

  .duri-icn-wrap-x1 {
    gap: 8px;
    padding: 0;
    margin-bottom: 16px;
    justify-content: center;
  }

  .duri-icn-lbl-x1 {
    justify-content: center;
    font-size: 12px;
    padding: 8px 16px;
  }

  .duri-logo-wrap-x1 {
    flex-direction: row;
    justify-content: center;
    gap: 16px;
  }

  .duri-hero-icns-x1 img {
    width: 60px;
    height: auto;
  }

  .duri-img-x1 {
    width: 100%;
    height: 100vh;
  }

  .duri-hero-subtxt-x1 {
    color: #FFF;
    font-family: "PP Mori";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 22.4px;
  }

  .duri-Banner-x1 .duri-btns-alt-x1 {
    gap: 8.76px;
    flex-direction: column;
  }
  a.duri-btn-alt-x1 {
    display: flex;
    height: 60px;
    padding: 15px 32.92px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: #732727;
    max-width: 196px;
    margin: 0 auto;
    width: 100%;
  }
  .duri-btn-label4-x1 {
    font-size: 16px;
    line-height: 19.2px;
  }
  .duri-Banner-x1 .duri-hero-heading-x1 {
    text-align: center;
    max-width: 288px;
    margin: 0 auto;
  }
  .duri-hero-heading-x1 { display: none; }
  .duri-hero-heading-mbl-x1 {
    display: block;
    padding-top: 12px;
    padding-bottom: 8px;
    letter-spacing: 0px;
    text-align: start;
    color: #FFF;
    font-family: "PP Mori";
    font-size: 38px;
    font-style: normal;
    font-weight: 600;
    line-height: 49.4px;
    margin: 0;
  }
}
</style>

<section class="duri-sec-{{ section.id }}-pad {% if section.settings.enable_highlight-chz-bnr %}duri-Banner-x1{% endif %} {% if section.settings.enable_highlight-country-page %}duri-Banner-country-x1{% endif %}">
  <div class="duri-bnr-bg-x1">
    {{ section.settings.cf-banner-video | video_tag:
            widths: '50, 100, 150, 200, 250, 300, 400, 500, 600',
            alt: "video",
            class: 'duri-img-x1',
            loading: "eager",
            autoplay: true,
            loop: true,
            muted: true,
            playsinline: true,
            id: 'cf-banner-video'
          }}
    {% if section.settings.cheeseBnrImg != blank %}
      <img class="duri-img-x1" src="{{ section.settings.cheeseBnrImg | image_url }}" loading="lazy" width="100%" height="">
    {% endif %}
    {% if section.settings.cheeseBnrImg1 != blank %}
      <img class="duri-img-mbl-x1" src="{{ section.settings.cheeseBnrImg1 | image_url }}" loading="lazy" width="100%" height="">
    {% endif %}
  </div>

  <div class="duri-hero-content-x1">
    <div class="duri-stars-wrap-x1">
      <div class="duri-hero-stars-x1">★★★★★</div>
      <div class="duri-hero-stars-x1">1000+ Reviews</div>
    </div>

    <h1 class="duri-hero-heading-x1">{{ section.settings.heading }}</h1>
    <h1 class="duri-hero-heading-mbl-x1">{{ section.settings.headingMBL }}</h1>

    <div class="duri-hero-subtxt-x1">{{ section.settings.subtextt }}</div>

    <a href="{{ section.settings.button_link }}" class="duri-btn-main-x1">
      <p class="duri-btn-label-x1">{{ section.settings.button_label }}</p>
    </a>

    <div class="duri-btns-alt-x1">
      <a href="{{ section.settings.button_link4 }}" class="duri-btn-alt-x1">
        <p class="duri-btn-label4-x1">{{ section.settings.button_label4 }}</p>
      </a>
      <a href="{{ section.settings.button_link5 }}" class="duri-btn-alt-x1">
        <p class="duri-btn-label4-x1">{{ section.settings.button_label5 }}</p>
      </a>
    </div>

    <div class="duri-hero-icns-x1">
      <div class="duri-icn-wrap-x1">
        <div class="duri-icn-lbl-x1">  {% render 'cheese-logo1' %} 100% Risk Free</div>
        <div class="duri-icn-lbl-x1"> {% render 'cheese-logo' %} 500,000+ Sold</div>
      </div>

      <div class="duri-logo-wrap-x1">
        {% if section.settings.logo1 != blank %}
          <img src="{{ section.settings.logo1 | image_url: width: 120 }}" alt="Logo 1">
        {% endif %}
        {% if section.settings.logo2 != blank %}
          <img src="{{ section.settings.logo2 | image_url: width: 120 }}" alt="Logo 2">
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Duri Banner about us",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back-color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "cheeseBnrImg",
      "label": "cheeseBnrImg"
    },
    {
      "type": "video",
      "id": "cf-banner-video",
      "label": "cheeseBnrImg"
    },
    {
      "type": "image_picker",
      "id": "cheeseBnrImg1",
      "label": "cheeseBnrImg1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "headingMBL",
      "label": "Heading Mobile"
    },
    {
      "type": "richtext",
      "id": "subtextt",
      "label": "subtext"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "text",
      "id": "button_label4",
      "label": "Button Label",
      "default": "Request Form"
    },
    {
      "type": "text",
      "id": "button_label5",
      "label": "Button Label",
      "default": "CALL US"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "url",
      "id": "button_link4",
      "label": "Button Link"
    },
    {
      "type": "url",
      "id": "button_link5",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "logo1",
      "label": "Logo 1 (e.g. PA Preferred)"
    },
    {
      "type": "image_picker",
      "id": "logo2",
      "label": "Logo 2 (e.g. Dairy of Distinction)"
    },
    {
      "type": "checkbox",
      "id": "enable_highlight-chz-bnr",
      "label": "Cheese Banner",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_highlight-country-page",
      "label": "Cheese Banner Country Page",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Duri Banner about us",
      "category": "Custom"
    }
  ]
}
{% endschema %}
