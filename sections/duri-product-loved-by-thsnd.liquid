        {% comment %} <button class='slick-prev slick-arrow cs_reviews_prev'><svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 30 30' fill='none'><circle cx='15' cy='15' r='14.5' fill='white' stroke='#194C4F'/><path d='M12.5811 19.355L17.4198 15.0001L12.5811 10.6453' stroke='#194C4F' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg></button>
        <button class='slick-next slick-arrow cs_reviews_next'><svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 30 30' fill='none'><circle cx='15' cy='15' r='14.5' fill='white' stroke='#194C4F'/><path d='M12.5811 19.355L17.4198 15.0001L12.5811 10.6453' stroke='#194C4F' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg></button> {% endcomment %}
       </div>
     </div>
   </section>
  {% comment %} </div> {% endcomment %}
<script>
    var swiper = new Swiper(".my-reviews-Swiper", {
    slidesPerView: 4,
    spaceBetween: 20,
    centeredSlides: true,
    loop: true,
    navigation: {
      nextEl: ".custom-reviews-next", // ✅ your custom button
      prevEl: ".custom-reviews-prev", // ✅ your custom button
    },
    pagination: {
      el:('.swiper-pagination'),
      type: 'progressbar',
    },
    breakpoints: {
      0: {
        slidesPerView: 1.2,
        spaceBetween: 10,
        centeredSlides: false,
      },
      768: {
        slidesPerView: 2,
        spaceBetween: 15,
        centeredSlides: false,
      },
      1024: {
        slidesPerView: 4,
        spaceBetween: 20,
        centeredSlides: false,
      }
    },
  });
</script>
