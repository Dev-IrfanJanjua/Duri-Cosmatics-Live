{% schema %}
  {
      "name": "Duri Product Lvd by Thsnd",
    "settings": [
      {
        "type": "richtext",
        "id": "heading",
        "label": "Hading"
      },
      {
        "type": "text",
        "id": "sub-heading",
        "label": "Counting"
      },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top Padding",
      "default": 10
    },
       {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 10
    },  
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top Padding Mobile",
      "default": 40
    },
       {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom Padding Mobile",
      "default": 10
    },  
    {
      "type": "color",
      "id": "back-ground",
      "label": "Section Background Color"
    },
    {
      "type": "color_background",
      "id": "bg_card",
      "label": "Cards Background Color"
    },
    {
      "type": "image_picker",
      "id": "image_stars",
      "label": "Stars Image"
    },
    {
      "type": "image_picker",
      "id": "image_buyer",
      "label": "Buyer Icon Image"
    }
     
    ],
    "blocks": [
      {
        "type": "blocks",
        "name": "blocks",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "block-heading",
            "label": "Heading"
          },
          {
            "type": "richtext",
            "id": "para",
            "label": "Block Para"
          },
          {
            "type": "text",
            "id": "name",
            "label": "Name"
          },
          {
            "type": "text",
            "id": "varified-text",
            "label": "Varified Text"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Duri Product Lvd by Thsnd"
      }
    ]
  }
{% endschema %}