{% style %}
.section-{{ section.id }}--padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-ground }};
    position: relative;
  }
.custom-reviews-parent {
    padding-left: 80px;
    padding-right: 80px;
}
  .custom-reviews-heading p strong{
    magrin: 0;
    font-family: Poppins;
    font-size: 40px;
    font-weight: 700;
    line-height: 37px;
    letter-spacing: 0.5px;
    text-align: center;
    text-underline-position: from-font;
    text-decoration-skip-ink: none;
    color: linear-gradient(90deg, #0D2628 5.47%, #32999E 52.73%, #0D2628 100%);
  }
  
.custom-reviews-heading p {
    margin: 0;
    text-align: center;
    
    padding-bottom: 24px;
    color: #000 !important;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 36px;
    line-height: 46.8px;
    letter-spacing: 0px;
    vertical-align: middle;
}
.duri-card-btm {
    padding: 20px 10px;
    text-align: center;
    border: 2px solid var(--Mid-Pink, #D99CA5);
    border-top: none;
    height: 100%;
        display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
}
  /* .custom-reviews-parent-bottom{
    margin-top: 42px;
  } */
  .custom-reviews-block-contant{
    background: #fff;
    display: flex;
    flex-direction: column;
  }
.custom-reviews-block-contant img {
    max-width: 100%;
    max-height: 257px;
    object-fit: cover;
    display: block;
}
.custom-reviews-block-stars {
    line-height: 0;
    width: 88px;
    height: auto;
    text-align: center;
}

.custom-reviews-block-stars img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
}
  .custom-reviews-block-heading {
    margin: 0;
    text-transform: capitalize;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 14px;
    line-height: 20.8px;
    letter-spacing: 0;
    vertical-align: middle;
    color: #000;
}
.duri-card-btm_head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: space-between;
    height: auto;
}
.duri-card-btm_head_info {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
}
  .custom-reviews-para p{
    margin: 0;
    text-align: center;
    padding: 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
}
  .custom-reviews-bottom-parent{
    display: flex;
   justify-content: space-between;
    align-items: center;
  }
  .custom-reviews-name {
    margin: 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 16px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    color: #404040;
}
  .custom-reviews-verified-text {
    margin: 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 16px;
    letter-spacing: 0;
    vertical-align: middle;
    color: #404040;
}
.custom-reviews-verified {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 4px;
    line-height: 0;
}
  .custom-reviews-parent-bottom .slick-next {
    bottom: 0px !important;
    top: unset;
    /* width: 50%; */
    width: 40px !important;
    text-align: start;
    right: 46%;
    height: 40px;
    background: #6c4e72;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
}
  .custom-reviews-parent-bottom .slick-prev {
    bottom: 0px !important;
    top: unset;
    /* width: 50%; */
    text-align: end;
    left: 47%;
    background: #6c4e72;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
}
  .custom-reviews-parent-bottom .slick-prev:before{
    display: none;
  }
  .custom-reviews-parent-bottom .slick-track{
    display: flex;
    gap: 14px;
  }
  .custom-reviews-section-top-section svg{
   width: 100%;
    height: 100%;
    display: block;
    line-height: 0;
  }
  .custom-reviews-section-top-section{
    position: absolute;
    top: -77px;
    width: 100%;
  }
  .custom-reviews-section-top-section-mobile{
       display: none;
     }
  .slick-prev svg{
      transform: rotate(180deg);
  }
  .slick-arrow svg circle {
    stroke: none;
    fill: none;
  }
  .slick-arrow svg path {
    stroke: white;
  }
span.custom-reviews-verified-icon {
    min-width: 16px;
    max-width: 16px;
    height: 16px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
}

span.custom-reviews-verified-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.custom-reviews-swiper_bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-direction: row-reverse;
    gap: 22px;
    margin-top: 24px;
}

.custom-reviews-navigation {
    display: flex;
    gap: 7px;
    align-items: center;
}

.custom-reviews-arrow {
    width: 48px;
    height: 48px;
    display: block;
    min-width: 48px;
    cursor: pointer;
}

.custom-reviews-arrow svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
}

.custom-reviews-progress {
    position: static;
    background-color: #D99CA580;
    height: 2px !important;
}

.custom-reviews-progress span.swiper-pagination-progressbar-fill {
    background-color: #D99CA5 !important;
}

.custom-reviews-arrow.swiper-button-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
}


.section-{{ section.id }}--padding .swiper-slide {
    display: flex;
    height: auto;
}
   @media (max-width: 768px) {
    .section-{{ section.id }}--padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }

    .section-{{ section.id }}--padding .page-width {
    padding-right: 0;
}
     .custom-reviews-block-stars svg {
        height: auto;
        width: 88px;
    }
    .custom-reviews-block-contant img{
        max-height: 219px;
    }
     .custom-reviews-heading p{
       font-size: 35px;
       line-height: 30.6px;
       padding-bottom: 20px;
     }
     .custom-reviews-block-heading{
       font-size: 14px;
       line-height: 21px;
     }
     .custom-reviews-para p{
       font-size: 14px;
       line-height: 21px;
        padding: 0;
     }
     .custom-reviews-name{
        font-size: 12px;
       line-height: 18.3px;
     }
     .custom-reviews-heading p strong{
        font-size: 35px;
       line-height: 30px;
     } 
     .custom-reviews-verified-text{
        font-size: 11px;
       line-height: 16.77px;
     }
     .custom-reviews-parent-bottom .slick-track {
        gap: 13px;
   }
     .custom-reviews-block-stars {
       margin: 0;
     }
     .custom-reviews-parent-bottom .slick-prev{
          left: 39%;
      z-index: 2;
    }
    .custom-reviews-parent-bottom .slick-next{
      z-index: 2;
      right: 39%;
    }
    .custom-reviews-parent-bottom .slick-dots li{
    width: 6px;
    height: 6px;
  }
   .custom-reviews-parent-bottom .slick-dots li.slick-active button:before{
    outline: 1px solid #194C4F;
    border-radius: 50%;
  }
  .custom-reviews-parent-bottom .slick-dots li button:before{
    font-size: 8px;
    color: #194C4F;
    opacity: 1;
    width: 12px;
    height: 12px;
    line-height: 14px;
  }
  .custom-reviews-parent-bottom .slick-dots{
        bottom: -27px;
  }
  .custom-reviews-section-top-section {
    top: -20px;
    display: none;
 }
     .custom-reviews-section-top-section-mobile{
        display: block;
        width: 100%;
        position: absolute;
        top: -48px;
     }
    .custom-reviews-section-top-section-mobile svg{
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
     }
.custom-reviews-heading p {
    font-size: 24px;
    line-height: 31.2px;
    font-weight: 600;
    text-align: center;
    margin: 0 auto;
    padding-right: 23px;
    padding-left: 7px;
    padding-bottom: 16px;
}

    .custom-reviews-swiper_bottom {
    display: none;
}
     
   }
  {% endstyle %}
  {% comment %} <div class="happy-top-div"> {% endcomment %}
   <section class="section-{{ section.id }}--padding" id="reviews_sec">
     <!-- <div class="custom-reviews-section-top-section">{% render 'custom-reviews-section-top-section-svg' %}</div>
     <div class="custom-reviews-section-top-section-mobile">{% render 'custom-reviews-section-top-section-mobile-svg' %}</div> -->
     <div class="page-width">
       <div class="custom-reviews-parent-top">
         <div class="custom-reviews-heading">{{ section.settings.heading }}</div>
       </div>
       <div class="custom-reviews-parent-bottom">
        <div class="swiper my-reviews-Swiper">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide">
                <div class="custom-reviews-block-contant" style="background-color: {{ section.settings.bg_card }}">
                    <img src="{{ block.settings.image | image_url }}" loading="lazy" width="100%" height="auto">
                    <div class="duri-card-btm">
                      <div class="duri-card-btm_head">
                        <div class="duri-card-btm_head_info">
                          {% if section.settings.image_stars != blank %}
                            <div class="custom-reviews-block-stars">
                              {{ section.settings.image_stars | image_url: width: 500 | image_tag:
                                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                    alt: "image",
                                    loading: "lazy"
                                }}
                            </div>
                          {% endif %}
                          <h2 class="custom-reviews-block-heading">{{ block.settings.block-heading }}</h2>
                        </div>
                        {% if block.settings.para != blank %}
                          <div class="custom-reviews-para">{{ block.settings.para }}</div>
                        {% endif %}
                      </div>
                      <div class="custom-reviews-bottom-parent">
                        <div class="custom-reviews-name">{{ block.settings.name }}</div>
                        <div class="custom-reviews-verified">
                          {% if section.settings.image_buyer != blank %}
                            <span class="custom-reviews-verified-icon">
                              {{ section.settings.image_buyer | image_url: width: 500 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  alt: "image",
                                  loading: "lazy"
                              }}
                          </span>
                          {% endif %}
                          <span class="custom-reviews-verified-text">{{ block.settings.varified-text }}</span>
                        </div>
                      </div>
                  </div>
              </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <div class="custom-reviews-swiper_bottom">
          <!-- Desktop Navigation -->
          <div class="custom-reviews-navigation">
