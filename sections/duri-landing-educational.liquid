<style>
.educational-detail-section {
  padding: 40px 0;
  font-family: inherit;
  text-align: center;
  background: #FFF4F3;
}

.edu-title {
    margin: 0 0 24px;
    color: #000;
    font-family: "PP Mori";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: 46.8px;
}

.edu-subtitle {
  font-size: 16px;
  color: #555;
  margin: 0 0 20px;
  color: #000;
  font-family: "PP Mori";
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 21px;
}

.edu-tabs {
  display: flex;
  justify-content: center;
  gap: 12px;
  list-style: none;
  padding: 0;
  margin: 0 0 24px;
}

.edu-tab {
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  padding: 12px 24px;
  justify-content: center;
  align-items: center;
  gap: 10px;
  flex: 1 0 0;
  max-width: 302px;
  color: #000;
  text-align: center;
  font-family: "PP Mori";
  font-size: 16px;
  font-style: normal;
  font-weight: 600;
  line-height: 20.8px;
  {% comment %} border: 1px solid #CADBD8; {% endcomment %}
}

.edu-tab.active {
        color: #000;
    border: 1px solid #D99CA5;
    background: #FFF;
    box-shadow: 0 4px 0 0 #7C0732;
}

.edu-content {
  display: none;
  margin-top: 0px;
}

.edu-content.active {
  display: block;
}

.how-to-images {
  display: flex;
  gap: 20px;
  justify-content: space-between;
  flex-wrap: wrap;
}

.how-to-card {
      position: relative;
    line-height: 0;
    max-width: calc( 33.3% - 13.7px);
    width: 100%;
}
.how-to-card img {
    max-width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.how-label {
    position: absolute;
    top: 14px;
    left: 14px;
    background: #fff;
    padding: 5px 10px;
    display: block !important;
    border-radius: 0;
    font-weight: 600;
    font-size: 12px;
    line-height: 100% !important;
    letter-spacing: 0px;
    text-transform: uppercase;
    font-family: 'PP Mori';
    color: #7C0732;
}

.faq-wrapper {
  text-align: left;
  max-width: 910px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.faq-item {
    padding: 15px 24px;
    border: 1.2px solid #FDCED2;
    background: #fff;
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
    gap: 10px;
}

.faq-item_content {
    max-width: 100%;
    width: 100%;
}

.faq-question {
    cursor: pointer;
    font-family: 'PP Mori';
    font-weight: 600;
    font-size: 18px;
    line-height: 100%;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #65243F;
    transition: all 0.3s ease;
}

.faq-item.active .faq-question {
    padding-bottom: 10px;
}

.faq-answer {
    {% comment %} display: none; {% endcomment %}
      max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
    font-family: 'PP Mori';
    font-weight: 400;
    font-size: 16px;
    line-height: 22.4px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #65243F;
}

.faq-item .faq-item_icon{
  width: 15px;
  height: 8px;
}

.faq-item .faq-item_icon svg{
  width: 100%;
  height: 100%;
  display: block;
}

.faq-item.active .faq-item_icon {
  transform: rotate(180deg);
  transition: transform 0.3s ease;
}


.ingredients-wrapper {
  display: flex;
  gap: 20px;
  justify-content: center;
  max-width: 909px;
  align-items: center;
  text-align: center;
  margin: 0 auto;
}

.ingredient-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 200px;
    width: 100%;
    text-align: left;
    background: #fff;
    padding: 30px;
    border-radius: 10px;
}

.ingredient-item {
    padding: 10px;
    border-radius: 15px;
    cursor: pointer;
    color: #000;
    font-family: 'PP Mori';
    font-weight: 600;
    font-size: 13.75px;
    line-height: 100%;
    letter-spacing: 0px;
    vertical-align: middle;
}

.ingredient-item.active {
    background: #FED0BB;
    color: #000;
}

.ingredient-details {
  flex: 1;
  text-align: left;
}

.ingredient-detail {
    display: none;
    background: #fff;
    border-radius: 10px;
    padding: 8px 20px;
}

.ingredient-detail.active {
    display: flex;
    align-items: center;
}
.ingredient-detail img {
    max-width: 200px;
}

.ingredient-detail p {
    font-family: 'PP Mori';
    font-weight: 500;
    font-size: 16px;
    line-height: 22.4px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
    margin: 0;
}
@media screen and (max-width: 768px) {
  .edu-tabs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-bottom: 8px;
}
.educational-detail-section {
    padding: 40px 0;
}
.how-to-card img {
    max-width: 100%; 
}
.edu-title {
  font-size: 24px;
  line-height: 31px;
  margin-bottom: 8px;
}
.edu-subtitle {
  font-size: 14px;
  margin-bottom: 16px;
}
.how-to-images {
    gap: 16px;
}

.how-to-card {
    max-width: 100%;
}

.faq-question {
    font-size: 14px;
}

.faq-answer {
    font-size: 12px;
    line-height: 120%;
}

.edu-tab {
  font-size: 14px;
  padding: 12px 8px;
}
.ingredients-wrapper {
  flex-direction: column;
}
.ingredient-detail img {
  max-width: 100%;
  width: 100%;
}
.ingredient-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    max-width: 100%;
    width: 100% !important;
    padding: 20px;
    gap: 12px;
}

.ingredient-detail {
    padding: 20px;
    flex-direction: column;
    gap: 20px;
}

.ingredient-detail p {
    font-size: 14px;
    line-height: 20px;
}

.ingredient-list {
  width: unset;
}
}
</style>

<div class="educational-detail-section">
  <div class="page-width">
    <div class="educational-detail-container">
      <h2 class="edu-title">{{ section.settings.title }}</h2>
  
      <!-- Tabs Navigation -->
      <ul class="edu-tabs">
        <li class="edu-tab active" data-tab="how-to">{{ section.settings.tab1_title }}</li>
        <li class="edu-tab" data-tab="faqs">{{ section.settings.tab2_title }}</li>
        <li class="edu-tab" data-tab="ingredients">{{ section.settings.tab3_title }}</li>
        {% comment %} <li class="edu-tab" data-tab="growth">{{ section.settings.tab4_title }}</li> {% endcomment %}
      </ul>
  
      <p class="edu-subtitle">{{ section.settings.subtitle }}</p>
      <!-- Tab Content -->
      <div class="edu-tab-content">
  
        <!-- TAB 1: How to Use -->
        <div class="edu-content active" id="how-to">
          <div class="how-to-images">
            {% for block in section.blocks %}
              {% if block.type == 'how_to_image' %}
                <div class="how-to-card">
                  <img src="{{ block.settings.image | img_url: '600x' }}" alt="">
                  {% if block.settings.label != blank %}
                    <span class="how-label">{{ block.settings.label }}</span>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <p class="how-to-text">{{ section.settings.how_to_text }}</p>
        </div>
  
        <!-- TAB 2: FAQs -->
        <div class="edu-content" id="faqs">
          <div class="faq-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'faq' %}
                <div class="faq-item">
                  <div class="faq-item_content">
                    <div class="faq-question">{{ block.settings.question }}</div>
                    <div class="faq-answer">{{ block.settings.answer }}</div>
                  </div>
                  <div class="faq-item_icon">
                    <svg width="19" height="12" viewBox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M1.625 9.42188L9.42368 1.62319L17.2224 9.42188" stroke="black" stroke-width="3.24945" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
  
        <!-- TAB 3: Ingredients -->
        <div class="edu-content" id="ingredients">
          <div class="ingredients-wrapper">
            <div class="ingredient-list">
              {% for block in section.blocks %}
                {% if block.type == 'ingredient' %}
                  <div class="ingredient-item {% if forloop.first %}active{% endif %}" data-target="ingredient-{{ forloop.index }}">
                    {{ block.settings.name }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            <div class="ingredient-details">
              {% for block in section.blocks %}
                {% if block.type == 'ingredient' %}
                  <div class="ingredient-detail {% if forloop.first %}active{% endif %}" id="ingredient-{{ forloop.index }}">
                    <img src="{{ block.settings.image | img_url: '400x' }}" alt="">
                    <p>{{ block.settings.description }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
  
        <!-- TAB 4: Nail Growth Guide -->
        {% comment %} <div class="edu-content" id="growth">
          <p>{{ section.settings.growth_text }}</p>
        </div> {% endcomment %}
  
      </div>
    </div>
  </div>
</div>

