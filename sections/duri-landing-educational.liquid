    { 
        "type": "text", 
        "id": "tab1_title", 
        "label": "Tab 1 Title", 
        "default": "How to Use Rejuvacote" 
    },
    { 
        "type": "text", 
        "id": "tab2_title", 
        "label": "Tab 2 Title", 
