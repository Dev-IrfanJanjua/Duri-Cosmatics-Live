<style>
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-color}};
}
.trusted-section_wrapper {
    display: flex;
    flex-direction: row-reverse;
    gap: 60px;
    justify-content: space-between;
}
.trusted-right,
.trusted-left {
    line-height: 0;
    max-width: calc(50% - 30px);
    width: 100%;
}
img.trusted-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
}

.hero-hed-subtext {
    margin: 0;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
    text-align: left;
}
.hero-hed-subtext a {
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-weight: 400;
    line-height: 21px;
    text-decoration: none;
    text-decoration: underline;
}
.trust-block-main {
    display: flex;
    flex-direction: column;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--Mid-Pink, #D99CA5);
    gap: 14px;
}
.trust-block-main:last-child {
    border-bottom: none;
}
.trust-left-heading {
    margin: 0;
    color: #000;
    font-family: "PP Mori";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: 46.8px;
    text-align: start;
    letter-spacing: 0;
}
.trust-left-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 32px;
    background: {{ section.settings.bg_faq }};
}
.block-svg-neww {
    align-items: center;
    gap: 16px;
}
.trust-left-main {
    text-align: center;
    gap: 24px;
    display: flex;
    flex-direction: column;
    width: 100%;
}
.trust-block-head {
    text-align: start;
    color: #000;
    font-family: "PP Mori";
    font-size: 20px;
    font-style: normal;
    font-weight: 600;
    line-height: 30px;
    margin: 0;
    letter-spacing: 0;
}
.trust-block-rich {
    margin: 0;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
    text-align: start;
    letter-spacing: 0;
}
.trustgiftNEW img.trusted-image {
    width: 100%;
    height: auto;
    max-width: 610px;
    min-width: 610px;
    max-height: 610px;
}
.trustgiftNEW .trusted-main {
    display: flex;
    flex-direction: row-reverse;
    justify-content: center;
    align-items: center;
    gap: 60px;
}
.trustgiftNEW .block-svg-neww {
    display: unset; 
    align-items: unset; 
}
.trustgiftNEW .trust-left-main {
    margin-right: 0px;
    margin-left: 0px;
    align-items: center;
    min-width: 600px;
}
.trustgiftNEW .trust-block-main {
    max-width: 100%;
    padding: 32px 32px 0 32px;
}
.trustgiftNEW .trust-left-main {
    align-items: unset;
}
.trustgiftNEW .trust-left-block {
    gap: 0;
}
.trustgiftNEW .trust-block-rich {
    padding-bottom: 16px;
    border-bottom: 1px solid #7BA69D66;
}
.trustgiftNEW .trust-block-main:nth-of-type(3) {
    padding-bottom: 32px;
}

.trust-block-main.trust-block-main_last {
    padding: 0;
    border: none;
}
@media screen and (max-width: 768px) {
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-color}};
    padding-top: 0;
    padding-bottom: 0px;
}
.section-{{ section.id }}-padding .page-width {
    padding: 0;
}
.trusted-section_wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
}
.hero-hed-subtext {
    font-size: 12px;
    line-height: 18.2px; /* 151.667% */
}
.trusted-main {
    flex-direction: column;
}
.trusted-left {
    padding: 40px 16px;
}
.trusted-right, .trusted-left {
    max-width: 100%;
}
.trust-left-main {
    gap: 12px;
}
.trust-block-main {
    gap: 10px;
}

.trust-left-heading {
    font-size: 24px;
    line-height: 31.2px;
    text-align: left;
}
.trust-left-main {
    text-align: left;
}
.trust-block-head {
    font-size: 16px;
    padding-bottom: unset;
    line-height: 20.8px;
}
.trustgiftNEW .trusted-main {
    flex-direction: column;
    gap: 40px;
}
.trustgiftNEW img.trusted-image {
    max-width: unset;
    min-width: unset;
    max-height: unset;
}
.trustgiftNEW .trust-left-main {
    min-width: unset;
    padding: 0px 16px 0px 16px;
    margin: 0;
}
.trustgiftNEW .trust-left-heading {
    text-align: start;
    max-width: unset;
}
.trustgiftNEW .trust-block-main {
    padding: 22px 20px 0 20px;
}
.trust-left-block {
    padding: 22px 20px;
}

}
</style>
<section class="section-{{ section.id }}-padding {% if section.settings.enable_highlight_TRUSTED %}trustgiftNEW{% endif %}" id="faqs_section">
    <div class="page-width">
        <div class="trusted-section_wrapper">
            <div class="trusted-right">
                <img class="trusted-image" src="{{ section.settings.trust-img | image_url }}" loading="lazy" width="100%" height="100%">
            </div>
            <div class="trusted-left">
                <div class="trust-left-main">
                    <p class="trust-left-heading">{{ section.settings.heading}}</p>
                    <div class="trust-left-block">
                        {% for block in section.blocks %}
                            <div class="trust-block-main {%  if forloop.last %}trust-block-main_last{% endif %}">
                                <div class="block-svg-neww">
                                    <div class="trust-svg"> {{ block.settings.custom_svg }} </div>
                                    <div class="block-heading">
                                        <p class="trust-block-head">{{ block.settings.blockheading}}</p>
                                    </div>
                                </div>
                                <div class="trust-richtxt">
                                    <div class="trust-block-rich">{{ block.settings.subtext}}</div>
                                </div>
                            </div>
                            {% endfor %}
                    </div>
                    {% if section.settings.ir_subtexxtt != blank %}
                        <div class="hero-hed-subtext">
                            {{ section.settings.ir_subtexxtt }}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>
{% schema %}
  {
    "name": "Duri product freqntly ask",
    "settings": [
        {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding Top",
        "default": 10
        },
        {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding Bottom",
        "default": 10
        },
        {
        "type": "range",
        "id": "mbl_padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Mobile Top Padding",
        "default": 10
        },
        {
        "type": "range",
        "id": "mbl_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px", 
        "label": "Mobile Bottom Padding",              
        "default": 10
        },
        {
        "type": "color", 
        "id": "back-color",
        "label": "Background Color"
        },
        {
            "type": "color", 
            "id": "bg_faq",
            "label": "Faqs content Background"
        },
        {
        "type": "image_picker",
        "id": "trust-img",
        "label": "Main Img"
        },
        {
        "type": "text",
        "id": "heading",
        "label": "heading"
        },
        {
        "type": "inline_richtext",
        "id": "ir_subtexxtt",
        "label": "rich text"
        },
        { 
        "type": "checkbox",
        "id": "enable_highlight_TRUSTED",
        "label": "enable highlight TRUSTED",
        "default": false
        }
    ],
    "blocks": [
        {
            "type": "blocks",
            "name": "add-slider",
            "settings": [
                {
                    "type": "html",
                    "id": "custom_svg",
                    "label": "SVG markup",
                },
                {
                    "type": "text",
                    "id": "blockheading",
                    "label": "blockheading",
                },
                {
                    "type": "inline_richtext",
                    "id": "subtext",
                    "label": "subtext",
                }
            ]
        }
    ],
    "presets": [
      {
        "name": "Duri product freqntly ask"
      }
    ]
  }
{% endschema %}