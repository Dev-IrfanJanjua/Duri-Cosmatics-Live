{% style %}
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.desktop-padding-top }}px;
    padding-bottom: {{ section.settings.desktop-padding-bottom }}px;
    background-color: {{ section.settings.back-color }};
    overflow: hidden;
}
.custom-content {
    padding: 0px 80px 80px 80px;
}
.flex-container {
    display: flex;
}
.custom-video {
  width: 100%;
  height: 60vh;
  object-fit: cover;
  position: relative;
  z-index: 12;
}
.video-container {
  position: relative;
  z-index: 10;
}
.play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  cursor: pointer;
  z-index: 20;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}
.product-gallery {
  display: flex;
  gap: 16px;
  padding: 12px 16px;
  justify-content: center;
}
.product-gallery img {
  width: 60px;
  height: 60px;
}
p.custom-subhead {
    margin: 0 auto;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 16px;
    line-height: 21px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    padding-bottom: 24px;
}
p.product-title {
  margin: 0;
  color: var(--6, #404040);
  font-family: "Twentieth Century";
  font-size: 14px;
  font-weight: 500;
  line-height: 18px;
  text-transform: uppercase;
  padding-bottom: 8px;
}
span.product-price {
  color: var(--6, #404040);
  font-family: "Twentieth Century";
  font-size: 14px;
  font-weight: 350;
}
span.compare-price {
  color: var(--7, #A4A4A4);
  font-family: "Twentieth Century";
  font-size: 14px;
  font-weight: 350;
  text-decoration: underline;
}
.price-section {
  display: flex;
  align-items: center;
  gap: 8px;
}
.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.custom-heading {
  margin: 0;
  padding: 0px 16px;
  text-align: center;
}
.custom-heading p {
    margin: 0;
    padding-bottom: 14px;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 36px;
    line-height: 46.8px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    color: #000;
}
.custom-heading p strong {
  color: var(--1, #6A2590);
  font-weight: 400;
}
.wrapper {
  position: relative;
}
.prev-button {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  left: 24px;
  z-index: 999;
  cursor: pointer;
}
.next-button {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  right: 24px;
  z-index: 999;
  cursor: pointer;
}
.arrow-section {
  display: flex;
}
.product-info p{
    font-family: PP Mori;
    font-weight: 400;
    font-style: Regular;
    font-size: 14px;
    line-height: 23.4px;
    letter-spacing: 0px;
    display: flex;
    align-items: center;
}
.product-info strong {
    font-family: PP Mori;
    font-weight: 400;
    font-style: Regular;
    font-size: 48px;
    line-height: 48px;
    letter-spacing: 0;
    text-align: center;
}
.custom-subhead {
  display: flex;
  justify-content: center;
}
.custom-subheadmbl {
  display: none;
}

/* Responsive */
@media screen and (max-width: 1100px) {
  .wrapper::before,
  .wrapper::after { width: 120px; }
  .product-gallery img { width: 50px; height: 50px; }
}
@media screen and (max-width: 768px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding-top-mbl }}px;
    padding-bottom: {{ section.settings.padding-bottom-mbl }}px;
  }
  .custom-subhead {
  display: none;
}
.custom-subheadmbl {
        display: flex;
        margin: 0;
        text-align: center;
        padding-right: 16px;
    }
  .custom-content {
    padding: unset;
}
.product-info p {
    font-size: 12px;
}
.custom-content {
    padding-left: 16px !important;
}
  .wrapper::before,
  .wrapper::after { 
    content: unset; 
}
  .prev-button, .next-button { 
    display: none; 
}
  .custom-heading p {
    font-size: 23px;
    line-height: 31.2px;
    padding: 0px 16px 8px 0px;
}
p.custom-subhead {
    padding-right: 16px;
}
  .product-gallery img { 
    width: 36px; 
    height: 36px; 
}
  p.product-title { 
    font-size: 12px; 
    padding-bottom: 4px; 
}
  span.product-price, span.compare-price { 
    font-size: 10px; 
}
}
{% endstyle %}

<section class="section-{{ section.id }}-padding custom-section">
  <div class="custom-content">
    <h3 class="custom-heading">{{ section.settings.heading }}</h3>
    <p class="custom-subhead">{{ section.settings.subhead }}</p>
    <p class="custom-subheadmbl">{{ section.settings.subheadmbl }}</p>
    <div class="wrapper">
      <div class="swiper custom-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
          {% assign product = block.settings.product %}
          <div class="swiper-slide">
            <div class="custom-card">
              <div class="video-container">
                {% if block.settings.video != blank %}
                  {{ block.settings.video | video_tag: class: 'custom-video', image_size: '1100x', controls: false, muted: false, id: 'custom-video-block' }}
                {% endif %}
                <div class="play-icon">{% render 'play-svg-new' %}</div>
              </div>
              <div class="flex-container">
                <div><h3 class="product-info">{{ block.settings.title12 }}</h3></div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
var swiper = new Swiper(".custom-swiper", {
  slidesPerView: 4,
  spaceBetween: 20,
  speed: 800,
  loop: true,
  navigation: {
    nextEl: ".next-button",
    prevEl: ".prev-button",
  },
  breakpoints: {
    0: { slidesPerView: 1.2, spaceBetween: 12 },
    768: { slidesPerView: 3, spaceBetween: 14 },
    1024: { slidesPerView: 4, spaceBetween: 20 }
  }
});

document.addEventListener("DOMContentLoaded", function () {
  const videoContainers = document.querySelectorAll(".video-container");

  videoContainers.forEach(container => {
    const video = container.querySelector("video");
    const playIcon = container.querySelector(".play-icon");

    playIcon.style.display = "flex";

    playIcon.addEventListener("click", function () {
      if (video.paused) {
        video.play();
        playIcon.style.display = "none";
      }
    });

    video.addEventListener("click", function () {
      if (!video.paused) {
        video.pause();
        playIcon.style.display = "flex";
      }
    });

    video.addEventListener("play", function () {
      document.querySelectorAll(".video-container video").forEach(v => {
        if (v !== video) {
          v.pause();
          v.closest(".video-container").querySelector(".play-icon").style.display = "flex";
        }
      });
    });
  });
});
</script>

