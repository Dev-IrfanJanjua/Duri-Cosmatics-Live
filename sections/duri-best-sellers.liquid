<style>
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        background-color: {{ section.settings.back-color}};
    }
    .section-{{ section.id }}-padding{
      padding-left: 80px;
    }

    .section-{{ section.id }}-padding .page-width{
      padding-right: 0px;
      margin-right: 0px;
    }

    a{
      text-decoration:none;
    }
      .single-product-image img {
        width: 100%;
        height: auto;
        background-size: contain;
        object-fit: contain;
        display: block;
        height: 333px;
    }
    .single-product-card {
      background: #FFF;
      border-radius: 12px;
      display: flex;
      height: auto;
       /*padding: 20px;
      box-shadow: 0 0 8px rgba(0,0,0,0.05);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      max-width: 280px;*/
    }
    .discount-text{
          color: black;
        text-align: center;
        font-family: 'PP Mori';
        font-size: 19px;
        font-style: normal;
        font-weight: 400;
        line-height: 14.3px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-top: 15px;
    }
    .discount-off{
        color: black;
        font-family: 'PP Mori';
        font-size: 12px;
        font-style: normal;
        font-weight: 400;
        line-height: 14.3px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        justify-content: center;
      }
    .single-product-image {
      position: relative;
      border-radius: 12px;
      /* overflow: hidden; */
    }

    .discount-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #FFF4F3;
        padding: 0px 0px;
        border-radius: 50%;
        text-align: center;
        width: 60px;
        height: 60px;
    }

    .rating-stars {
      display: flex;
      gap: 6px;
    }

    .single-product-title {
      color: var(--DARK-GREY, #333232);
      font-family: Satoshi;
      font-size: 18px;
      font-style: normal;
      font-weight: 700;
      line-height: 26px;
      /* min-height:60px; */
    }

    .product-description {
      {% comment %} min-height: 84px; {% endcomment %}
      margin: 0;
      color: #000;
      font-family: "PP Mori";
      font-size: 14px;
      font-style: normal;
      font-weight: 400;
      line-height: 21px;
      letter-spacing: 0;
  }

    .price-container {
      margin-bottom: 4px;
      letter-spacing: 0;
      display: flex
  ;
      flex-direction: row-reverse;
      gap: 5px;
    }

    .collection-compare-price {
    text-align: right;
    text-decoration-line: line-through;
    color: #8C8C8C;;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px; /* 150% */
    }

    .collection-price {
        text-align: right;
        color: #000;
        font-family: "PP Mori";
        font-size: 14px;
        font-style: normal;
        font-weight: 400;
        line-height: 21px; /* 150% */
    }

    .collection-btn-shop-now {
          background-color: #3f4fff;
        transition: background-color 0.6s ease, color 0.6s ease, border 0.6s ease !important;
        border: none;
        padding: 12px 0;
        border-radius: 25px;
        cursor: pointer;
        width: 100%;
        color: #FFF;
        text-align: center;
        font-family: Satoshi;
        font-size: 18px;
        font-style: normal;
        font-weight: 700;
        line-height: 22px;
    }

    .collection-btn-shop-now:hover {
        background-color: transparent;
        color: #3f4fff;
        border: 1px solid;
    }
    .rate-text .metafield-rich_text_field p{
    color: #3B3B3B;
    text-align: right;
    font-family: Satoshi;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 18px; /* 128.571% */
    }
    .main-wrapper-title-rating-cont{
    display: flex;
    padding:20px;
    justify-content: center;
    /* align-items: center; */
    flex-direction: column;
    gap: 7.17px;
    {% comment %} padding-bottom: 0; {% endcomment %}
     background: #fff;
    }
    .collection-wrap{
      display: flex;
      justify-content: center;

    }
    .main-text-with-collection{
      position: relative;
    }
    .main-heading-collection {
        text-align: start;
        color: #000;
        font-family: "PP Mori";
        font-size: 36px;
        font-style: normal;
        font-weight: 600;
        line-height: 46.8px; /* 130% */
        margin: 0;
        padding-bottom: 24px;
        letter-spacing: 0;
    }

    .main-text-with-collection{
      margin: 0 auto;
      padding-left: 0;
    }
    .single-product-image .best-seller-badge{
      margin: 10px;
      position: absolute;
      right: 10px;
      background-color: #121A5B;
    }
    .collection-btn-shop {
      display: flex;
      width: 32px;
      height: 32px;
      padding: 0.5px;
      justify-content: center;
      align-items: center;
      border: none;
      cursor: pointer;
  }
  .price-and-btn {
      display: flex;
      justify-content: space-between;
      align-items: center;
  }
  .cs_swiper-bar_buttons{
          width: 90%;
          position: absolute;
      bottom: -50px;
      top: unset;
    }
    .css_swiper_navigation{
      display: flex;
    }
    .new-collection-products-wrapper {
      padding-bottom: 0px;
    }
    .collection-wrap .swiper-scrollbar-drag {
      display: block;
      background: #9CBCB5;
    }
    .collection-wrap .swiper-scrollbar.swiper-scrollbar-horizontal {
      height: 2px;
      width: 84%;
    }
    .btn-maiNN {
      position: absolute;
      bottom: -29px;
      right: 80px;
      z-index: 99;
      display: flex;
      gap: 15px;
      flex-direction: row-reverse;
    }
    .swiper-button-nexttt svg rect,  .swiper-button-prevvv svg rect{
      stroke: #9CBCB5;
    }
    .swiper-button-disabled svg rect, .swiper-button-disabled rect{
      stroke: #D9D9D9;
    }
    {% comment %} .swiper-button-prevvv svg {
      border: 1px solid #9CBCB5;
    } {% endcomment %}

    .bounce-up .quick-add__submit:after{
    content: none !important;
  }
  .bounce-up .quick-add__submit:before{
    content: none !important;
  }
  .bounce-up .button--full-width {
      display: flex
  ;
      width: 100%;
      /* width: 14px; */
      min-width: -3px;
      min-width: 32px;
      width: 32px;
      padding: 0px;
      letter-spacing: 0px;
      min-height: 32px;
      border: none;
      box-shadow: navajowhite;
  }
  .bounce-up .button--full-width svg{
    width: 32px;
    height: 32px;
  }

  a.single-product-card_btn {
      display: flex;
      flex-direction: column;
      border: 1px solid #7BA69D66;
  }

  a.single-product-card_btn.single-product-card_btn-1 {
      border-left: 1px solid #7BA69D66;
  }

  .swiper-button_btn {
      cursor: pointer;
      height: 48px;
      width: 48px;
  }

  .main-btn-clas {
    position: static;
    display: flex;
    gap: 22px;
    align-items: center;
    padding-right: 80px;
    margin-top: 24px;
}

.collection-wrap .swiper-scrollbar.swiper-scrollbar-horizontal,
.btn-maiNN {
    position: static !important;
}

.collection-wrap .swiper-scrollbar.swiper-scrollbar-horizontal {
    width: 100%;
}

.new-collection-products-wrapper .swiper-wrapper{
  height: auto;
}

    @media screen and (max-width: 768px){
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.mbl_padding_top }}px;
        padding-bottom: {{ section.settings.mbl_padding_bottom}}px;
    }
    .section-{{ section.id }}-padding{
      padding-left: 16px;
    }
    .single-product-title{
      font-size:18px;
    }
    .price-container{
          margin-bottom: 20px;
    }
    .main-text-with-collection {
      padding-left: 0;
    }
    .main-heading-collection{
      font-size: 24px;
      padding-bottom: 16px;
      line-height: 31.2px;
    }
    .collection-price{
      margin-left: 0px;
    }
    .price-container {
      margin-bottom: 0;
    }
    .cs_swiper-bar_buttons {
      display: none;
    }
    .btn-maiNN, .main-btn-clas{
      display: none;
    }
    .new-collection-products-wrapper {
      padding-bottom: 0px;
  }
  .single-product-image img {
      height: 280px;
  }

  }
</style>

<section class="section-{{ section.id }}-padding bounce-up">
  {% comment %} <div class="page-width"> {% endcomment %}
  <div class="main-text-with-collection">
    <div class="main-text-box">
      <h2 class="main-heading-collection">{{ section.settings['heading-discover'] }}</h2>
      {% comment %}
        <div class="shopeAll-button">
          <a href="{{ section.settings.shopeAll-href }}" class="btn-shopeAll">
            {{- section.settings['btn-shopeAll'] }}
          </a>
        </div>
      {% endcomment %}
    </div>
    <div class="collection-wrap">
      <div class="new-collection-products-wrapper swiper collections-cards-slider">
        <div class="swiper-wrapper">
          {% for card_product in section.settings.collection.products %}
            <div class="single-product-card swiper-slide">
              <a
                class="single-product-card_btn single-product-card_btn-{{ forloop.index }}"
                href="{{ card_product.url }}"
              >
                <div class="single-product-image">
                  {% if card_product.tags contains 'Best Seller' %}
                    <div class="best-seller-badge">Best Seller</div>
                  {% endif %}
                  <img
                    src="{{ card_product.featured_image | img_url: '400x400' }}"
                    loading="lazy"
                    class="product-image-primary"
                    alt="{{ card_product.title }}"
                  >
                  {% if card_product.compare_at_price > product.price %}
                    {% assign discount = card_product.compare_at_price
                      | minus: card_product.price
                      | times: 100
                      | divided_by: card_product.compare_at_price
                      | round
                    %}
                    <div class="discount-badge">
                      <span class="discount-text"> {{ discount }}% </span>
                      <span class="discount-off">OFF</span>
                    </div>
                  {% endif %}
                </div>
                <div class="main-wrapper-title-rating-cont">
                  <div class="rating-stars">
                    {% render 'star-svg' %}
                    <span class="rate-text">{{ card_product.metafields.custom.rating_text | metafield_tag }}</span>
                    <!-- Replace 200 with dynamic if needed -->
                  </div>
                  {% comment %} <p class="single-product-title">{{ product.title | truncate: 50 }}</p> {% endcomment %}
                  <p class="product-description">{{ card_product.description | strip_html | truncate: 80 }}</p>
                  <div class="price-and-btn">
                    <div class="price-container">
                      {% if card_product.compare_at_price > card_product.price %}
                        <span class="collection-compare-price">{{ card_product.compare_at_price | money }}</span>
                      {% endif %}
                      <span class="collection-price">{{ card_product.price | money }}</span>
                    </div>
                    {% comment %} <button class="collection-btn-shop">{% render 'btn-svg' %}</button> {% endcomment %}
                    {% assign quick_add = section.settings.quick_add %}
                    {% assign section_id = section.id %}
                    {% assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id %}
                    {% if quick_add == 'standard' %}
                      <div class="quick-add no-js-hidden">
                        {%- liquid
                          assign qty_rules = false
                          if card_product.selected_or_first_available_variant.quantity_rule.min > 1 or card_product.selected_or_first_available_variant.quantity_rule.max != null or card_product.selected_or_first_available_variant.quantity_rule.increment > 1
                            assign qty_rules = true
                          endif
                        -%}
                        {%- if card_product.variants_count > 1 or qty_rules -%}
                          <modal-opener data-modal="#QuickAdd-{{ card_product.id }}">
                            <button
                              id="{{ product_form_id }}-submit"
                              type="submit"
                              name="add"
                              class="quick-add__submit button button--full-width button--secondary{% if horizontal_quick_add %} card--horizontal__quick-add animate-arrow{% endif %}"
                              aria-haspopup="dialog"
                              aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
                              data-product-url="{{ card_product.url }}"
                            >
                              {{ 'products.product.choose_options' | t }}
                              {%- if horizontal_quick_add -%}
                                <span class="icon-wrap">
                                  {{- 'icon-arrow.svg' | inline_asset_content -}}
                                </span>
                              {%- endif -%}
                              {%- render 'loading-spinner' -%}
                            </button>
                          </modal-opener>
                          <quick-add-modal id="QuickAdd-{{ card_product.id }}" class="quick-add-modal">
                            <div
                              role="dialog"
                              aria-label="{{ 'products.product.choose_product_options' | t: product_name: card_product.title | escape }}"
                              aria-modal="true"
                              class="quick-add-modal__content global-settings-popup"
                              tabindex="-1"
                            >
                              <button
                                id="ModalClose-{{ card_product.id }}"
                                type="button"
                                class="quick-add-modal__toggle"
                                aria-label="{{ 'accessibility.close' | t }}"
                              >
                                {{- 'icon-close.svg' | inline_asset_content -}}
                              </button>
                              <div id="QuickAddInfo-{{ card_product.id }}" class="quick-add-modal__content-info"></div>
                            </div>
                          </quick-add-modal>
                        {%- else -%}
                          <product-form data-section-id="{{ section.id }}">
                            {%- form 'product',
                              card_product,
                              id: product_form_id,
                              class: 'form',
                              novalidate: 'novalidate',
                              data-type: 'add-to-cart-form'
                            -%}
                              <input
                                type="hidden"
                                name="id"
                                value="{{ card_product.selected_or_first_available_variant.id }}"
                                class="product-variant-id"
                                {% if card_product.selected_or_first_available_variant.available == false %}
                                  disabled
                                {% endif %}
                              >
                              <button
                                id="{{ product_form_id }}-submit"
                                type="submit"
                                name="add"
                                class="quick-add__submit button button--full-width button--secondary{% if horizontal_quick_add %} card--horizontal__quick-add{% endif %}"
                                aria-haspopup="dialog"
                                aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
                                aria-live="polite"
                                data-sold-out-message="true"
                                {% if card_product.selected_or_first_available_variant.available == false %}
                                  disabled
                                {% endif %}
                              >
                                {% comment %}
                                  <span>
                                    {%- if card_product.selected_or_first_available_variant.available -%}
                                      {{ 'products.product.add_to_cart' | t }}
                                    {%- else -%}
                                      {{ 'products.product.sold_out' | t }}
                                    {%- endif -%}
                                  </span>
                                {% endcomment %}
                                {% render 'btn-svg' %}
                                <span class="sold-out-message hidden">
                                  {{ 'products.product.sold_out' | t }}
                                </span>
                                {%- if horizontal_quick_add -%}
                                  <span class="icon-wrap">
                                    {{- 'icon-plus.svg' | inline_asset_content -}}
                                  </span>
                                {%- endif -%}
                                {%- render 'loading-spinner' -%}
                              </button>
                            {%- endform -%}
                          </product-form>
                        {%- endif -%}
                      </div>
                    {% elsif quick_add == 'bulk' %}
                      {% if card_product.variants_count == 1 %}
                        <quick-add-bulk
                          data-min="{{ card_product.selected_or_first_available_variant.quantity_rule.min }}"
                          id="quick-add-bulk-{{ card_product.selected_or_first_available_variant.id }}-{{ section.id }}"
                          class="quick-add-bulk"
                          data-index="{{ card_product.selected_or_first_available_variant.id }}"
                        >
                          {% if card_product.selected_or_first_available_variant.available == false %}
                            <button
                              id="{{ product_form_id }}-submit"
                              type="submit"
                              name="add"
                              class="quick-add__submit button button--full-width button--secondary"
                              aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
                              data-sold-out-message="true"
                              disabled
                            >
                              <span>{{ 'products.product.sold_out' | t }}</span>
                              <span class="sold-out-message hidden">
                                {{ 'products.product.sold_out' | t }}
                              </span>
                            </button>
                          {% else %}
                            {% render 'quantity-input',
                              variant: card_product.selected_or_first_available_variant,
                              min: 0
                            %}
                          {% endif %}
                        </quick-add-bulk>
                      {% else %}
                        <div class="quick-add no-js-hidden">
                          {%- liquid
                            assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id
                            assign qty_rules = false
                            if card_product.selected_or_first_available_variant.quantity_rule.min > 1 or card_product.selected_or_first_available_variant.quantity_rule.max != null or card_product.selected_or_first_available_variant.quantity_rule.increment > 1
                              assign qty_rules = true
                            endif
                          -%}
                          <modal-opener
                            id="QuickBulk-{{ card_product.id }}-{{ section_id }}"
                            data-modal="#QuickAddBulk-{{ card_product.id }}-{{ section.id }}"
                          >
                            <button
                              id="{{ product_form_id }}-submit"
                              type="submit"
                              name="add"
                              class="quick-add__submit button button--full-width button--secondary"
                              aria-haspopup="dialog"
                              aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ card_product.id }}"
                              data-product-url="{{ card_product.url }}"
                            >
                              {{ 'products.product.choose_options' | t }}
                              {%- render 'loading-spinner' -%}
                            </button>
                          </modal-opener>
                          <modal-dialog
                            id="QuickAddBulk-{{ card_product.id }}-{{ section_id }}"
                            class="quick-add-modal color-{{ section.settings.color_scheme }}"
                          >
                            <div
                              role="dialog"
                              aria-label="{{ 'products.product.choose_product_options' | t: product_name: card_product.title | escape }}"
                              aria-modal="true"
                              class="quick-add-modal__content quick-add-modal__content--bulk global-settings-popup"
                              tabindex="-1"
                            >
                              <button
                                id="ModalClose-{{ card_product.id }}"
                                type="button"
                                class="quick-add-modal__toggle"
                                aria-label="{{ 'accessibility.close' | t }}"
                              >
                                {{- 'icon-close.svg' | inline_asset_content -}}
                              </button>
                              <div
                                id="QuickAddInfo-{{ card_product.id }}"
                                class="quick-add-modal__content-info quick-add-modal__content-info--bulk"
                              >
                                <div class="quick-add__content-info__media">
                                  <div class="quick-add__info">
                                    {%- if card_product.featured_media -%}
                                      <div
                                        class="quick-add__product-media"
                                      >
                                        <div class="quick-add__product-container global-media-settings">
                                          {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
                                          <img
                                            srcset="
                                              {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                                              {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                                              {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                                              {%- if card_product.featured_media.width >= 720 -%}{{ card_product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                                              {%- if card_product.featured_media.width >= 940 -%}{{ card_product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                                              {%- if card_product.featured_media.width >= 1066 -%}{{ card_product.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                                              {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
                                            "
                                            src="{{ card_product.featured_media | image_url: width: 533 }}"
                                            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                                            alt="{{ card_product.featured_media.alt | escape }}"
                                            class="motion-reduce"
                                            {% unless lazy_load == false %}
                                              loading="lazy"
                                            {% endunless %}
                                            width="{{ card_product.featured_media.width }}"
                                            height="{{ card_product.featured_media.height }}"
                                          >
                                          {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
                                        </div>
                                      </div>
                                    {%- endif -%}
                                    <a
                                      {% if card_product == blank %}
                                        role="link" aria-disabled="true"
                                      {% else %}
                                        href="{{ card_product.url }}"
                                      {% endif %}
                                      class="link product__view-details animate-arrow small-hide medium-hide"
                                    >
                                      {{ 'products.product.view_full_details' | t -}}
                                      {{- 'icon-arrow.svg' | inline_asset_content -}}
                                    </a>
                                  </div>
                                  <div class="quick-add-modal__content-info--bulk-details large-up-hide">
                                    <a href="{{ card_product.url }}" class="full-unstyled-link">
                                      <h3>{{ card_product.title | escape }}</h3>
                                    </a>
                                    {% render 'price',
                                      product: card_product,
                                      price_class: '',
                                      show_compare_at_price: true
                                    %}
                                    {%- if card_product.quantity_price_breaks_configured? -%}
                                      <div class="card__information-volume-pricing-note">
                                        <span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
                                      </div>
                                    {%- endif -%}
                                  </div>
                                </div>
                                <div>
                                  <div class="quick-add-modal__content-info--bulk-details small-hide medium-hide">
                                    <a href="{{ card_product.url }}" class="full-unstyled-link">
                                      <h3 class="h2">
                                        {{ card_product.title | escape }}
                                      </h3>
                                    </a>
                                    {% render 'price',
                                      product: card_product,
                                      price_class: '',
                                      show_compare_at_price: true
                                    %}
                                    {%- if card_product.quantity_price_breaks_configured? -%}
                                      <div class="card__information-volume-pricing-note">
                                        <span class="caption">{{ 'products.product.volume_pricing.note' | t }}</span>
                                      </div>
                                    {%- endif -%}
                                  </div>
                                  <bulk-modal
                                    id="QuickBulkModal-{{ card_product.id }}-{{ section_id }}"
                                    data-url="{{ card_product.url }}"
                                    data-section-id="{{ section_id }}"
                                    data-product-id="{{ card_product.id }}"
                                  >
                                  </bulk-modal>
                                </div>
                              </div>
                            </div>
                          </modal-dialog>
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
        <div class="main-btn-clas">
            <div class="swiper-scrollbar"></div>
            <div class="btn-maiNN">
              <div class="swiper-button-nexttt swiper-button_btn">{% render 'my-first-btn' %}</div>
              <div class="swiper-button-prevvv swiper-button_btn">{% render 'my-second-btn' %}</div>
            </div>
          </div>
      </div>
    </div>
    {% comment %}
      <div class="cs_swiper-bar_buttons">
        <div class="css_swiper-pagination"></div>
        <div class="css_swiper_navigation">
          <div>next</div>
          <div>prev</div>
      </div>
        </div>
    {% endcomment %}
    {% comment %}
      <div class="shopeAll-button-mbl-new">
        <a href="{{ section.settings.shopeAll-href }}" class="btn-shopeAll">{{ section.settings['btn-shopeAll'] }}</a>
      </div>
    {% endcomment %}
  </div>
  {% comment %} </div> {% endcomment %}
</section>

<script>
  var swiper = new Swiper('.collections-cards-slider', {
    centeredSlides: false, // Default to false (do not center for larger screens)
    slidesPerView: 3.9,
    spaceBetween: 30,
      scrollbar: {
        el: ".swiper-scrollbar",
      },
      {% comment %} navigation: {
        nextEl: ".swiper-button-nexttt",
        prevEl: ".swiper-button-prevvv",
      }, {% endcomment %}
    breakpoints: {
      320: {
        slidesPerView: 1.2,
        spaceBetween: 10,
        {% comment %} centeredSlides: true, // Enable centeredSlides on mobile (320px) {% endcomment %}
      },
      640: {
        slidesPerView: 2,
        spaceBetween: 20,
        {% comment %} centeredSlides: true, // Enable centeredSlides on small tablets (640px) {% endcomment %}
      },
      1024: {
        slidesPerView: 3.9,
        spaceBetween: 20,
        centeredSlides: false, // Disable centeredSlides for larger screens (1024px)
      },
      1660: {
        slidesPerView: 6,
        spaceBetween: 20,
        centeredSlides: false, // Disable centeredSlides for larger screens (1024px)
      },
    },
    navigation: {
      nextEl: '.swiper-button-nexttt',
      prevEl: '.swiper-button-prevvv',
    },
    loop: false,
  });
</script>

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

