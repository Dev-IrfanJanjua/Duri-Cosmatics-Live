<section class="product-feature-section">
  <div class="feature-grid">
    
    <!-- Left Content -->
    <div class="feature-content">
      <h2>{{ section.settings.heading }}</h2>
      <p class="feature-desc">{{ section.settings.text }}</p>

      <div class="feature-icons">
        {% for block in section.blocks %}
          <div class="feature-icon">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url }}" width="50" alt="icon" loading="lazy">
            {% endif %}
            <p>{{ block.settings.label }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Right Image -->
    <div class="feature-image">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url }}" width="800" alt="Feature Image" loading="lazy">
      {% endif %}
    </div>

  </div>
</section>

<style>
.product-feature-section {
  padding: 0px 0px;
}
.feature-content {
    max-width: 480px;
    padding: 40px;
    background: #FFF4F3;
    margin: 15px 80px;
}
.feature-grid {
  display: flex;
  align-items: center;
  line-height: 0;
}
.feature-content h2 {
    margin: 0;
    color: #000;
    font-family: "PP Mori";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: 46.8px;
    letter-spacing: 0;
}
.feature-content .feature-desc {
    margin: 0px;
    color: #444;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
    padding: 16px 0 36px 0;
    letter-spacing: 0;
}
.feature-icons {
  display: flex;
  gap: 20px;
}
.feature-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 120px;
}
.feature-icon img {
  width: 48px;
  height: 48px;
  object-fit: contain;
}
.feature-icon p {
    color: #000;
    text-align: center;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
    margin: 0;
    padding-top: 12px;
    letter-spacing: 0;
}
.feature-image img {
  width: 100%;
  object-fit: cover;
}
@media (max-width: 768px) {
  .feature-grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .feature-icons {
            gap: 5px;
        justify-content: space-between;
    
  }
  .feature-grid {
    flex-direction: column-reverse;
  }
  .feature-content {
    margin: 0;
    padding: 0;
    margin: 40px 16px 40px 16px;
    text-align: start;
    padding: 16px
  }
  .feature-content h2 {
    margin-bottom: 12px;
    margin-top: 0;
    font-size: 24px;
    color: #000;
    font-family: "PP Mori";
    font-size: 24px;
    font-style: normal;
    font-weight: 600;
    line-height: 31.2px;
  }
  .feature-content .feature-desc {
    margin-bottom: 16px;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
  }
  .feature-desc {
    margin-bottom: 16px;
    margin-top: 0;
  }
  .feature-icon {
    max-width: 91px;
  }
  .feature-icon p {
    margin: 0;
}
.feature-content .feature-desc {
  padding: 0;
}
 
}
</style>

{% schema %}
{
  "name": "duri rapidSHEILD",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RapidShield Polish Drying Drops"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Say goodbye to accidental smudges and hello to a long-lasting, professional finish..."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Image"
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Feature Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Clean, 8-Free Formulas"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "duri rapidSHEILD",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
