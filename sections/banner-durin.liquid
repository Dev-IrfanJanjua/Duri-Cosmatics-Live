{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    position: relative;
  }

  .section-abs-images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

h2.banner-title {
    font-family: PP Mori;
    font-weight: 600;
    font-size: 48px;
    line-height: 62.4px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: {{ section.settings.text_colot }};
    margin: 0 ;

}

p.banner-desc {
    margin: 8px 0 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 20px;
    line-height: 32px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: {{ section.settings.text_colot }};
}

a.banner-btn {
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    padding: 14px 50px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    backdrop-filter: blur(34.71186447143555px);
    font-family: PP Mori;
    font-weight: 600;
    font-size: 16px;
    line-height: 20px;
    letter-spacing: 0%;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    transition: all 0.3s ease;
    margin-top: 24px;
    cursor: pointer;
    border: 1px solid {{ section.settings.btn_bg }};
}

a.banner-btn:hover{
  /* transform: translateY(-3px); */
    border: 1px solid {{ section.settings.btn_bg }};
    background-color: transparent;
    color: {{ section.settings.btn_bg }};
}

.banner-wrapper {
    max-width: {{ section.settings.max_width }}px;
    position: absolute;
    top: 50%;
    left: 80px;
    transform: translateY(-50%);
}

  .banner_img-mob{
    display: none !important;
  }

  .whole-seller .banner-wrapper {
    bottom: 60px;
    transform: unset;
    top: auto;
}

.whole-seller h2.banner-title {
    font-size: 46px;
    line-height: 55px;
}



  @media screen and (max-width: 900px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    img.banner_img-desk {
    display: none;
}

img.banner_img-mob {
    display: block !important;
}

h2.banner-title {
    font-size: 38px;
    line-height: 45px;
}

.about-us h2.banner-title {
    font-size: 28px;
    line-height: 36.4px;
    margin-bottom: 12px;
}

.about-us .banner-wrapper {
    bottom: 40px;
}
.about-us a.banner-btn {
    padding: 11px 20px;
    margin-top: 24px;
    font-size: 14px;
}

.about-us p.banner-desc {
    font-size: 14px;
    line-height: 21px;
}

p.banner-desc {
    font-size: 16px;
    line-height: 22.4px;
}

a.banner-btn {
    padding: 10px 32px;
    margin-top: 16px;
    font-size: 14px;
}

.banner-wrapper {
    top: auto;
    bottom: 30px;
    left: 16px;
    right: 16px;
    transform: unset;
}

.whole-seller h2.banner-title {
    font-size: 28px;
    line-height: 36.4px;
    padding-right: 55px;
}
.whole-seller a.banner-btn {
    margin-top: 10px;
}

  }
{% endstyle %}

<section class="banner-section section-{{ section.id }}">
  <div class="section-abs-images">
    {% if section.settings.img_desk != blank %}
      {{ section.settings.img_desk | image_url: width: 2400 | image_tag:
          widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
          alt: "image",
          loading: "lazy",
          class: 'banner_img-desk'
      }}
    {% endif %}
    {% if section.settings.img_mob != blank %}
      {{ section.settings.img_mob | image_url: width: 2400 | image_tag:
          widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
          alt: "image",
          loading: "lazy",
          class: 'banner_img-mob'
      }}
    {% endif %}
  </div>

  <div class="page-width">
    <div class="banner-wrapper">
      <div class="banner-head">
        {% if section.settings.title != blank %}
          <h2 class="banner-title">
            {{ section.settings.title }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="banner-desc">
            {{ section.settings.description }}
          </p>
        {% endif %}
      </div>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="banner-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Banner Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "img_desk",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "img_mob",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Banner Heading"
    },
    {
      "type": "color",
      "id": "text_colot",
      "label": "Text Color",
      "default": "#000"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Add your banner description here."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content Width",
      "min": 400,
      "max": 800,
      "step": 5,
      "unit": "px",
      "default": 620
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#7C0732"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Color",
      "default": "#fff"
    },

    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Custom Banner Section",
      "category": "Duri"
    }
  ]
}
{% endschema %}
