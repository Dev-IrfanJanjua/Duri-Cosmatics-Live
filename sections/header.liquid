{% style %}

.cstm_header .header__icons.my-icons-local {
    gap: 20px;
}

.cstm_header .header__icons.my-icons-local .header__icon {
    width: 20px !important;
    height: 20px !important;
}

.cstm_header .header__icons.my-icons-local .header__icon svg {
    stroke: #3D3935 !important;
}

.cstm_header .header__icons.my-icons-local .desktop-localization-wrapper {
    display: none;
}

.cstm_header .header__icons.my-icons-local .header__icon span.svg-wrapper {
    width: 100%;
    height: 100%;
}

.cstm_header .cart-count-bubble {
    left: 12px;
    height: 14px;
    width: 14px;
    bottom: 10px;
}

.cstm_header .header__submenu > li {
    text-align: left;
}

@media screen and (max-width: 768px){

  .cstm_header .menu-drawer__utility-links a.menu-drawer__account {
    display: none;
}

  .cstm_header .cart-count-bubble {
    left: 14px;
    bottom: 14px;
}

  .cstm_header .header__icons.my-icons-local {
    gap: 8px;
}

.cstm_header .header__icons.my-icons-local .header__icon {
    width: 24px !important;
    height: 24px !important;
}

.cstm_header a.header__heading-link.link.link--text.focus-inset.my-menu-design {
    width: 41px;
    height: 41px;
}

.cstm_header header-drawer .menu-drawer-container summary.header__icon {
    width: 24px;
    height: 24px;
}

.cstm_header header-drawer {
    margin: 0;
}

}

{% endstyle %}

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
