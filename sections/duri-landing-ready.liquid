<style>
.section-{{ section.id }}-ready-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-color }};
}

.ready-main-wrapper {
    display: flex;
}

.ready-left-section {
    width: 50%;
    text-align: center;
    align-items: center;
    background: #7C0732;
    color: white;
    justify-content: center;
    display: flex;
}

.ready-left-inner {
    width: 100%;
    max-width: 394px;
}

.ready-right-section {
    width: 50%;
}

a.ready-buttonn {
    display: flex;
    height: 42px;
    padding: 16px 20px;
    justify-content: center;
    align-items: center;
    align-self: stretch;
    background: #fff;
    border: 1px solid #fff;
    max-width: 230px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease;
    margin: 0 auto;
}

.ready-buttonn::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: #7C0732;
    transition: all 0.3s ease;
    z-index: 0;
}

.ready-buttonn:hover::before {
    left: 0;
}

.ready-button-text {
        margin: 0;
    color: #7C0732;
    text-align: center;
    font-family: "PP Mori";
    font-size: 16px;
    font-weight: 600;
    line-height: 20px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
}

.ready-buttonn:hover .ready-button-text {
    color: #fff;
}

.ready-main-left-text {
    color: #FFF;
    text-align: center;
    font-family: "PP Mori";
    font-size: 36px;
    font-weight: 600;
    line-height: 46.8px;
    margin: 0 auto;
    letter-spacing: 0;
}

.ready-main-left-subtext {
    margin: 0;
    padding: 16px 0;
    color: #FFF;
    text-align: center;
    font-family: "PP Mori";
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
}

.ready-image {
    height: 100%;
}

@media screen and (max-width: 768px) {
    .section-{{ section.id }}-ready-padding {
        padding-top: 0px;
        padding-bottom: 0px;
    }

    .section-{{ section.id }}-ready-padding .page-width{
        padding: 0;
    }

    .ready-main-wrapper {
        display: flex;
        flex-direction: column;
    }

    .ready-right-section {
        width: 100%;
        line-height: 0;
    }

    .ready-left-section {
        width: 100%;
        padding: 80px 16px;
    }

    .ready-main-left-text {
        font-size: 24px;
        line-height: 30px;
    }

    .ready-main-left-subtext {
        font-size: 14px;
        line-height: 18.2px;
    }

    .ready-button-text {
    font-size: 14px;
}

}
</style>

<section class="section-{{ section.id }}-ready-padding">
    <div class="page-width">
        <div class="ready-main-wrapper">
            <div class="ready-right-section">
                <img class="ready-image" src="{{ section.settings.duri-ready-img | image_url }}" loading="lazy" width="100%" height="">
            </div>
            <div class="ready-left-section">
                <div class="ready-left-inner">
                    <p class="ready-main-left-text">{{ section.settings.duriFirsttext }}</p>
                    <p class="ready-main-left-subtext">{{ section.settings.duriFirsttext2 }}</p>
                    <a href="{{ section.settings.duri-button_link }}" class="ready-buttonn">
                        <p class="ready-button-text">{{ section.settings.duri-btnbutton_label }}</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Duri Landing Prdct Ready",
  "settings": [
    { 
      "type": "range", 
      "id": "padding_top", 
      "label": "Padding Top", 
      "min": 0, 
      "max": 100, 
      "step": 1, 
      "unit": "px", 
      "default": 10 
    },
    { 
      "type": "range", 
      "id": "padding_bottom", 
      "label": "Padding Bottom", 
      "min": 0, 
      "max": 100, 
      "step": 1, 
      "unit": "px", 
      "default": 10 
    },
    { 
      "type": "range", 
      "id": "mbl_padding_top", 
      "label": "Mobile Top Padding", 
      "min": 0, 
      "max": 100, 
      "step": 1, 
      "unit": "px", 
      "default": 10 
    },
    { 
      "type": "range", 
      "id": "mbl_padding_bottom", 
      "label": "Mobile Bottom Padding", 
      "min": 0, 
      "max": 100, 
      "step": 1, 
      "unit": "px", 
      "default": 10 
    },
    { 
      "type": "color", 
      "id": "back-color", 
      "label": "Background Color" 
    },
    { 
      "type": "image_picker", 
      "id": "duri-ready-img", 
      "label": "Ready Image" 
    },
    { 
      "type": "text", 
      "id": "duriFirsttext", 
      "label": "Main Text" 
    },
    { 
      "type": "text", 
      "id": "duriFirsttext2", 
      "label": "Sub Text" 
    },
    { 
      "type": "url", 
      "id": "duri-button_link", 
      "label": "Button Link" 
    },
    { 
      "type": "text", 
      "id": "duri-btnbutton_label", 
      "label": "Button Text" 
    }
  ],
  "presets": [
    { 
      "name": "Duri Landing Prdct Ready" 
    }
  ]
}
{% endschema %}
