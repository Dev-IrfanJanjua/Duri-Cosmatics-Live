<section class="wholesale-section section-{{ section.id }}">
  {% comment %} <div class="page-width"> {% endcomment %}
    <div class="wholesale-grid">
  
      <!-- Left Image -->
      <div class="wholesale-left">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url }}" width="auto" alt="Wholesale Image" loading="lazy">
        {% endif %}
      </div>
  
      <!-- Right Content -->
      <div class="wholesale-right">
        <div class="wholesale-right_content">
          <h2>{{ section.settings.heading }}</h2>
          <p class="wholesale-desc">{{ section.settings.description }}</p>
    
          <div class="wholesale-features">
            {% for block in section.blocks %}
              <div class="wholesale-item">
                {% if block.settings.icon != blank %}
                  <img class="wholesale-icon" src="{{ block.settings.icon | image_url }}" width="30" alt="icon" loading="lazy">
                {% endif %}
                <p>{{ block.settings.text }}</p>
              </div>
            {% endfor %}
          </div>
    
          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="wholesale-btn">
              {{ section.settings.button_label }}
            </a>
          {% endif %}
        </div>
      </div>
  
    </div>
  {% comment %} </div> {% endcomment %}
</section>

<style>
.section-{{ section.id }} {
  background: #fff;
}
.wholesale-item p {
  margin: 0;
  color: #000;
  font-family: "PP Mori";
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 25.2px; /* 130% */
  letter-spacing: 0;
}
.wholesale-grid {
  display: flex;
  gap: 0px;
  align-items: center;
  line-height: 0;
}
.wholesale-left {
    max-width: 50%;
    width: 100%;
}
.wholesale-left img {
  width: 100%;
  object-fit: cover;
}
.wholesale-right h2 {
  margin: 0px;
  color: #000;
  font-family: "PP Mori";
  font-size: 36px;
  font-style: normal;
  font-weight: 600;
  line-height: 46.8px;
}
.wholesale-right {
    max-width: 50%;
    width: 100%;
    padding: 40px 80px;

}
.wholesale-right_content{
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 16px;
    flex-shrink: 0;
    align-self: stretch;
    {% comment %} max-width: 480px; {% endcomment %}
    background: {{ section.settings.cotent_bg }}
}
.wholesale-desc {
    margin: 0px;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
    letter-spacing: 0;
}
.wholesale-features {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 16px;
}
.wholesale-item {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 15px;
  color: #333;
}
.wholesale-icon {
  width: 24px;
  height: 24px;
  object-fit: contain;
  flex-shrink: 0;
}
.wholesale-btn {
    display: inline-block;
    background: #7C0732;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    padding: 14px 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    line-height: 20px;
    text-transform: uppercase;
    border: 1px solid #7C0732;
}
.wholesale-btn:hover {
  {% comment %} background: #003a34; {% endcomment %}
   {% comment %} transform: translateY(-3px); {% endcomment %}
    border: 1px solid #7C0732;
    background-color: transparent;
    color: #7C0732;
}

.whole-seller .section-{{ section.id }} .page-width{
  padding-left: 0px;
}

.whole-seller .wholesale-right_content {
    padding: 32px;
}


@media (max-width: 768px) {

  .section-{{ section.id }} .page-width{
    padding: 0;
  }

  .wholesale-grid {
    text-align: center;
    flex-direction: column;
  }
  .wholesale-features {
    align-items: start;
    gap: 16px;
    margin-bottom: 0;
  }
  .wholesale-right {
    max-width: 100%;
    padding: 40px 16px 40px 16px;

}
.wholesale-right_content{
  text-align: start;
}
  .wholesale-left {
    max-width: 100%;
}
   .wholesale-right h2 {
    font-size: 24px;
    font-weight: 600;
    line-height: 31.2px;
}

.wholesale-item p{
  line-height: 21.2px;
}

a.wholesale-btn {
    font-size: 14px;
}

.whole-seller .wholesale-right_content {
    padding: 20px;
}

.wholesale-desc {
    font-size: 16px;
    color: #444;
    margin: 0px;
    line-height: 1.6;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
}
}
</style>

{% schema %}
{
  "name": "Duri Wholesale Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Partner With Duri Wholesale"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Join our wholesale program and enjoy exclusive access..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP ON FAIR"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
    },
    {
      "type": "color",
      "id": "cotent_bg",
      "label": "Content Background",
      "default": "#fff"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "text", "label": "Text", "default": "Bulk Pricing – maximize your margins" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duri Wholesale Section",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
    