<style> 
.philo-sec-{{ section.id }}-pad {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.back-color }};
}

.section-{{ section.id }} .page-width{
  padding: 0;
}

.philo-wrap-main {
  display: flex;
  flex-direction: row-reverse;
}

.philo-left-col {
    max-width: 50%;
    width: 100%;
    background: #FFF4F3;
    justify-content: center;
    display: flex;
    padding: 40px 80px;
    align-items: center;
}

.philo-left-inner {
  width: 100%;
  max-width: 480px;
}

.philo-right-col {
  max-width: 50%;
  width: 100%;
}

a.philo-btn {
  display: flex;
  height: 42px;
  padding: 14px 50px;
  justify-content: center;
  align-items: center;
  align-self: stretch;
  background: #1e4851;
  max-width: 190px;
  text-decoration: none;
}

p.philo-btn-label {
  margin: 0;
  color: var(--1, #1E4851);
  text-align: center;
  font-family: "PP Mori";
  font-size: 15px;
  font-weight: 600;
  line-height: 20px;
  text-transform: uppercase;
}

p.philo-main-text {
  color: #000;
  text-align: left;
  font-family: "PP Mori";
  font-size: 36px;
  font-style: normal;
  font-weight: 600;
  line-height: 46.8px;
  margin: 0 auto;
  letter-spacing: 0;
}

h4.philo-sub-text {
  font-family: "PP Mori";
  font-weight: 400;
  font-size: 14px;
  line-height: 21px;
  letter-spacing: 0;
  text-align: left;
  vertical-align: middle;
  margin: 0;
  padding-top: 16px;
  color: #000;
}
.philo-sub-text ul {
  padding-left: 21px;
  margin: 16px 0px 0px 0px;
}
.philo-sub-text ul li {
    line-height: 25.2px;
}
img.philo-img {
  height: 100%;
}

/* button hover effect */
a.philo-btn {
  display: flex;
  height: 42px;
  padding: 14px 50px;
  justify-content: center;
  align-items: center;
  background: #1E4851;
  max-width: 190px;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s ease;
}
a.philo-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: white;
  transition: all 0.3s ease;
  z-index: 0;
}
a.philo-btn:hover::before {
  left: 0;
}
a.philo-btn:hover {
  transform: scale(1.05);
}
p.philo-btn-label {
  position: relative;
  z-index: 1;
  transition: color 0.3s ease;
  color: #fff;
}
a.philo-btn:hover p.philo-btn-label {
  color: #1e4851;
}
.uniqueblk-main-title1stnew {
    margin: 0;
    padding-bottom: 16px;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: 3px;
    vertical-align: middle;
    color: #000;
    text-align: left;
}
/* responsive */
@media screen and (max-width: 768px) {
  .philo-sec-{{ section.id }}-pad {
    padding-top: {{ section.settings.mbl_padding_top }}px;
    padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
  }
  .uniqueblk-main-title1stnew {
    padding-bottom: 8px;
}
  .philo-wrap-main {
    flex-direction: column;
  }
  .philo-right-col {
    max-width: 100%;
    line-height: 0;
  }
  .philo-left-col {
    max-width: 100%;
    padding: 40px 16px;
  }
  p.philo-main-text {
    font-size: 28px;
    line-height: 36.4px;
  }
  h4.philo-sub-text {
    font-size: 14px;
  }
}
</style>

<section class="philo-sec-{{ section.id }}-pad section-{{ section.id }}">
  <div class="page-width">
    <div class="philo-wrap-main">
      <div class="philo-right-col">
        {% if section.settings.duri-ready-img != blank %}
          <img class="philo-img" src="{{ section.settings.duri-ready-img | image_url }}" loading="lazy" width="100%" height="">
        {% endif %}
      </div>
      <div class="philo-left-col">
        <div class="philo-left-inner">
          <div class="philo-left-content">
              <p class="uniqueblk-main-title1stnew">{{ section.settings.duriVeryFirsttextT }}</p>
            <p class="philo-main-text">{{ section.settings.duriFirsttext }}</p>
            <h4 class="philo-sub-text">{{ section.settings.duriFirsttext2 }}</h4>
            {% if section.settings.duri-button_link != blank and section.settings.duri-btnbutton_label != blank %}
              <a href="{{ section.settings.duri-button_link }}" class="philo-btn">
                <p class="philo-btn-label">{{ section.settings.duri-btnbutton_label }}</p>
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Duri Our Stry growth evol",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back-color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "duri-ready-img",
      "label": "Ready Image"
    },
    {
      "type": "text",
      "id": "duriVeryFirsttextT",
      "label": "Main Text"
    },
    {
      "type": "text",
      "id": "duriFirsttext",
      "label": "Main Text"
    },
    {
      "type": "richtext",
      "id": "duriFirsttext2",
      "label": "Sub Text"
    },
    {
      "type": "url",
      "id": "duri-button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "duri-btnbutton_label",
      "label": "Button Text"
    }
  ],
  "presets": [
    {
      "name": "Duri Our Stry growth evol"
    }
  ]
}
{% endschema %}
