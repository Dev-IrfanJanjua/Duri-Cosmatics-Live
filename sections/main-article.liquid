                      placeholder="{{ 'blogs.article.message' | t }}"
                    >{{ form.body }}</textarea>
                    <label class="form__label field__label" for="CommentForm-body">
                      {{- 'blogs.article.message' | t }}
                      <span aria-hidden="true">*</span></label
                    >
                  </div>
                  {%- if form.errors contains 'body' -%}
                    <small id="CommentForm-body-error">
                      <span class="form__message">
                        <span class="svg-wrapper">
                          {{- 'icon-error.svg' | inline_asset_content -}}
                        </span>
                        {{- 'blogs.article.message' | t }}
                        {{ form.errors.messages.body }}.</span
                      >
                    </small>
                  {%- endif -%}
                </div>
                {%- if blog.moderated? -%}
                  <p class="article-template__comment-warning caption">{{ 'blogs.article.moderated' | t }}</p>
                {%- endif -%}
                <input type="submit" class="button" value="{{ 'blogs.article.post' | t }}">
              {% endform %}
            </div>
          </div>
        {%- endif -%}
  {% endif %}
</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{
  "name": "t:sections.main-article.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "cstm_style",
      "label": "Enable Custom Stylling",
      "default": false
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "featured_image",
      "name": "t:sections.main-article.blocks.featured_image.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "image_height",
          "options": [
            {
              "value": "adapt",
              "label": "t:sections.main-article.blocks.featured_image.settings.image_height.options__1.label"
            },
            {
              "value": "small",
              "label": "t:sections.main-article.blocks.featured_image.settings.image_height.options__2.label"
            },
            {
              "value": "medium",
              "label": "t:sections.main-article.blocks.featured_image.settings.image_height.options__3.label"
            },
            {
              "value": "large",
              "label": "t:sections.main-article.blocks.featured_image.settings.image_height.options__4.label"
            }
          ],
          "default": "adapt",
          "label": "t:sections.main-article.blocks.featured_image.settings.image_height.label"
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.main-article.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "blog_show_date",
          "default": true,
          "label": "t:sections.main-article.blocks.title.settings.blog_show_date.label"
        },
        {
          "type": "checkbox",
          "id": "blog_show_author",
          "default": false,
          "label": "t:sections.main-article.blocks.title.settings.blog_show_author.label"
        }
      ]
    },
    {
      "type": "content",
      "name": "t:sections.main-article.blocks.content.name",
      "limit": 1
    },
    {
      "type": "share",
      "name": "t:sections.main-article.blocks.share.name",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "share_label",
          "label": "t:sections.main-article.blocks.share.settings.text.label",
          "default": "t:sections.main-article.blocks.share.settings.text.default"
        }
      ]
    }
  ]
}
{% endschema %}


{% style %}

.section{{ section.id }}{
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.section{{ section.id }} .page-width{
  margin-block: 0 !important;
}

.cstm_blog_inner {
    display: flex;
    gap: 40px;
    justify-content: space-between;
    flex-wrap: wrap;
}

.cstm_blogs_wrapper {
    max-width: 73%;
    width: 100%;
}

.section{{ section.id }} h1.article-template__title {
    font-family: PP Mori;
    font-weight: 600;
    font-size: 46px;
    line-height: 55px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
    margin: 0 0 12px !important;
}

.section{{ section.id }} span.circle-divider.caption-with-letter-spacing {
    font-family: PP Mori;
    font-weight: 400;
    font-size: 18px;
    line-height: 18px;
    letter-spacing: 0px;
    color: #141414;
}

header.cstm_blog_header {
    margin: 0 ;
}

/* ===== image start ==== */

.section{{ section.id }} .article-template__hero-container {
    max-width: 100% !important;
    width: 100% !important;
    height: auto;
}

.section{{ section.id }} .article-template__hero-adapt.media {
    position: static;
    padding: 0 !important;
    background-color: transparent;
}

.section{{ section.id }} .article-template__hero-adapt.media img {
    position: static !important;
    width: 100% !important;
    height: 100% !important;
    line-height: 0 !important;
    display: block !important;
    object-fit: contain;
}

/* ===== image end ==== */

.section{{ section.id }} .article-template__content.cstm_blog_content {
    margin: 40px 0 0;
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.section{{ section.id }} .article-template__content.cstm_blog_content p,
.section{{ section.id }} .article-template__content.cstm_blog_content li,
.section{{ section.id }} .article-template__content.cstm_blog_content a {
    margin: 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0px;
    color: #141414;
}

.section{{ section.id }} .article-template__content.cstm_blog_content a{
  cursor: pointer;
}

.section{{ section.id }} .article-template__content.cstm_blog_content h1{
  font-family: 'PP Mori';
  font-weight: 600;
  font-size: 28px;
  line-height: 30px;
  letter-spacing: 0px;
  color: #141414;
}

.section{{ section.id }} .article-template__content.cstm_blog_content h2,
.section{{ section.id }} .article-template__content.cstm_blog_content h3,
.section{{ section.id }} .article-template__content.cstm_blog_content h4,
.section{{ section.id }} .article-template__content.cstm_blog_content h5,
.section{{ section.id }} .article-template__content.cstm_blog_content h6
.section{{ section.id }} .article-template__content.cstm_blog_content ul{
  font-family: 'PP Mori';
  font-weight: 600;
  font-size: 20px;
  line-height: 24px;
  letter-spacing: 0px;
  color: #141414;
  margin: 0 0 12px;
}

.section{{ section.id }} span.cstm_blog_tag {
    font-family: 'PP Mori';
    font-weight: 400;
    font-size: 18px;
    line-height: 21px;
    letter-spacing: 0px;
    color: #AEAEB2;
    margin: 0 0 12px;
    display: block;
    text-transform: capitalize;
}

.article-template__content.cstm_blog_content:after {
    display: none;
}

/* ========= related blogs ========= */

.cstm_blog-related-wrapper {
    max-width: calc(27% - 40px);
    width: 100%;
}

.related-blog-card_img {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
}

.related-blog-card_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

h2.related-blogs_title {
    font-family: PP Mori;
    font-weight: 600;
    font-size: 20px;
    line-height: 30px;
    letter-spacing: 0px;
    margin: 0 0 20px;
    color: #141414;
}

.related-blog-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.related-blog-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

p.related-blog-author {
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 21px;
    letter-spacing: 0px;
    margin: 0;
    color: #AEAEB2;
}

h3.related-blog-card-title{
  margin: 12px 0;
}

h3.related-blog-card-title a {
    font-family: PP Mori;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0px;
    color: #000;
    text-decoration: none;
    cursor: pointer;
}

p.related-blog-date {
    font-family: PP Mori;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
    letter-spacing: 0px;
    color: #000;
    margin: 0;
}

a.read-article-btn {
    background-color: #7C0732;
    color: #fff;
    padding: 10px 31px;
    text-decoration: none;
    border: 1px solid #7C0732;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 16px;
    line-height: 20px;
    letter-spacing: 0%;
    text-align: center;
    vertical-align: middle;
    text-transform: capitalize;
    max-width: 160px;
    width: 100%;
    cursor: pointer;
    transition: all 0.3s ease;
}

a.read-article-btn:hover{
  transform: translatey(-3px);
}

@media screen and (max-width: 768px){

.section{{ section.id }}{
  padding-top: {{ section.settings.padding_top_mob }}px;
  padding-bottom: {{ section.settings.padding_bottom_mob }}px;
}

.section{{ section.id }} h1.article-template__title {
    font-size: 28px;
    line-height: 36.4px;
}

.section{{ section.id }} header.cstm_blog_header {
    margin: 0;
}

.section{{ section.id }} .article-template__content.cstm_blog_content {
    margin: 30px 0 0;
    display: flex;
    flex-direction: column;
    gap: 30px;
}

.section{{ section.id }} span.cstm_blog_tag.cstm_blog_tag_desk{
  display: none !important;
}

.section{{ section.id }} span.cstm_blog_tag.cstm_blog_tag_mob{
  display: block !important;
}

.cstm_blog_inner {
    gap: 30px;
}

.cstm_blogs_wrapper {
    max-width: 100%;
}

.cstm_blog-related-wrapper {
    max-width: 100%;
    margin-top: 10px;
}

}

{% endstyle %}