<script>
  document.addEventListener('DOMContentLoaded', () => {
    console.log('Script loaded - updating quantity, one-time, and subscription prices...');

    const qtyInputs = document.querySelectorAll('.qty-input');
    const priceNewElement = document.querySelector('.price-newew'); // One-time price
    const subscPriceContainer = document.querySelector('#subsc_price-uptd'); // Subscription price container
    const productQtyInput = document.querySelector('.buy-button-qty'); // Quantity input
    const sellingPlanInput = document.querySelector('.selling_plan_id'); // Selling plan input
    const btnPrice = document.querySelector('.btn-price'); // Button price display

    function updateAllValues() {
      const checkedQty = document.querySelector('.qty-input:checked');
      const isOneTime = document.querySelector('.onetime_input:checked');
      const isSubscription = document.querySelector('.subscription_input:checked');

      if (!checkedQty) return;

      const orgPrice = checkedQty.getAttribute('org-price');
      const disPrice = checkedQty.getAttribute('dis-price');
      const comparePrice = checkedQty.getAttribute('compare-price'); // ORIGINAL compare price
      const qtyValue = checkedQty.getAttribute('data-qty');
      const diffPrice = checkedQty.getAttribute('diff-price');

      // Update quantity input
      if (productQtyInput && qtyValue) {
        productQtyInput.value = qtyValue;
        console.log('Quantity updated to:', qtyValue);
      }

      // Update one-time price
      if (priceNewElement) {
        priceNewElement.textContent = orgPrice;
      }

      // Update subscription price container
      if (subscPriceContainer) {
        const priceDiscElement = subscPriceContainer.querySelector('.price-disc');
        const priceOrgcElement = subscPriceContainer.querySelector('.price-newABC');

        if (priceDiscElement) priceDiscElement.textContent = disPrice;
        {% comment %} if (priceOrgcElement) priceOrgcElement.textContent = orgPrice; {% endcomment %}
        if (priceOrgcElement) priceOrgcElement.textContent = comparePrice;
      }

      // Update button price
      {% comment %} if (btnPrice) {
        if (isOneTime) btnPrice.innerText = orgPrice;
        else if (isSubscription) btnPrice.innerText = disPrice;
      } {% endcomment %}

      if (btnPrice) {
        if (isSubscription) {
          // Show compare price + discounted price using spans
          btnPrice.innerHTML = `
          <span class="actual-price">${disPrice}</span>
          <span class="compare-price">${comparePrice}</span>
          `;
          console.log('DEBUG: ATC button updated (subscription):', btnPrice.innerHTML);
        } 
        else if (isOneTime) {
          // Show compare price + price for one-time (using spans for CSS)
          btnPrice.innerHTML = `
          <span class="actual-price">${orgPrice}</span>
          <span class="compare-price">${comparePrice}</span>
          `;
          console.log('DEBUG: ATC button updated (one-time):', btnPrice.innerHTML);
        }
      }

      // Update selling plan
       if (sellingPlanInput) {
        const checkedPurchase = document.querySelector('input[name="purchase_type"]:checked');
        if (checkedPurchase?.classList.contains('subscription_input')) {
          sellingPlanInput.value = checkedPurchase.value;
          console.log('Selling plan set to subscription ID:', checkedPurchase.value);
        } else {
          sellingPlanInput.value = '';
          console.log('Selling plan cleared (one-time selected)');
        }
      } 
    }

    // Run on page load
    updateAllValues();

    // Event listeners for quantity radios
    qtyInputs.forEach(input => {
      input.addEventListener('change', updateAllValues);
    });

    // Event listeners for subscription / one-time radios
    document.querySelectorAll('.onetime_input, .subscription_input').forEach(input => {
      input.addEventListener('change', updateAllValues);
    });
  });
</script>
