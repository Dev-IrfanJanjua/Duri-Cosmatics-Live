  <script>
   document.addEventListener('DOMContentLoaded', () => {
    console.log('Script loaded - starting quantity, price, and selling plan sync...');

    // Select elements
    const qtyInputs = document.querySelectorAll('.qty-input');
    const productQtyInput = document.querySelector('.buy-button-qty');
    const priceNewElement = document.querySelector('.price-newew');
    const priceDiscElement = document.querySelector('.price-disc');
    const priceOrgcElement = document.querySelector('.price-newABC');
    const sellingPlanInput = document.querySelector('.selling_plan_id');
    const saveAmountElement = document.querySelector('#save-amount');


    // Function to update quantity, prices, and selling plan
    function updateValues(checkedInput) {
      if (!checkedInput) {
        console.warn('No checked input found.');
        return;
      }

      // Update quantity
      if (productQtyInput) {
        const qtyValue = checkedInput.getAttribute('data-qty');
        if (qtyValue) {
          productQtyInput.value = qtyValue;
          console.log(`Updated quantity to: ${qtyValue}`);
        } else {
          console.warn('No data-qty attribute found on checked input.');
        }
      }

      // Update original price
      if (priceNewElement) {
        const orgPrice = checkedInput.getAttribute('org-price');
        const diffPrice =  checkedInput.getAttribute('diff-price');
        if (orgPrice) {
          priceNewElement.textContent = orgPrice;
          saveAmountElement.textContent = diffPrice;
          console.log(`Updated original price to: ${orgPrice}`);
        } else {
          console.warn('No org-price attribute found on checked input.');
        }
      }

      // Update discounted price
      if (priceDiscElement) {
        const disPrice = checkedInput.getAttribute('dis-price');
         const OrgPrice = checkedInput.getAttribute('org-price');
        if (disPrice) {
          priceDiscElement.textContent = disPrice;
          priceOrgcElement.textContent = OrgPrice
          console.log(`Updated discounted price to: ${disPrice}`);
        } else {
          console.warn('No dis-price attribute found on checked input.');
        }
      }

      // Update selling plan
      if (sellingPlanInput) {
        if (checkedInput.classList.contains('onetime_input')) {
          sellingPlanInput.value = '';
          console.log('Onetime input checked: selling_plan_id set to empty.');
        } else if (checkedInput.classList.contains('subscription_input')) {
          const planValue = checkedInput.value;
          sellingPlanInput.value = planValue;
          console.log(`Subscription input checked: selling_plan_id set to ${planValue}`);
        } else {
          console.warn('Checked input is neither .onetime_input nor .subscription_input.');
        }
      }
    }

    // Set initial values on page load
    const initialChecked = document.querySelector('.qty-input:checked');
    if (initialChecked) {
      updateValues(initialChecked);
    } else {
      console.warn('No initially checked input found.');
    }

    // Update on change events
    qtyInputs.forEach(input => {
      input.addEventListener('change', () => {
        console.log('Change event triggered on:', input);
        if (input.checked) {
          updateValues(input);
        }
      });
    });

    console.log('Quantity, price, and selling plan sync setup complete.');
  });
  </script>

  <script>
   document.addEventListener('DOMContentLoaded', () => {
    // Function to update the price
    const updatePrice = () => {
      // Find the checked radio inputs
      const checkedQtyInput = document.querySelector('.qty-input:checked');
      const isOneTimeChecked = document.querySelector('.onetime_input:checked');
      const isSubscriptionChecked = document.querySelector('.subscription_input:checked');

      // Default price
      {% comment %} let price = '$0.00'; {% endcomment %}

      // Check if qty-input is selected and determine price based on onetime or subscription
      if (checkedQtyInput) {
        if (isOneTimeChecked) {
          price = checkedQtyInput.getAttribute('org-price');
        } else if (isSubscriptionChecked) {
          price = checkedQtyInput.getAttribute('dis-price');
        }
      }

      // Update the .btn-price element's innerText
      document.querySelector('.btn-price').innerText = price;
    };

    // Run on initial load
    updatePrice();

    // Add event listeners for changes to all relevant radio inputs
    document.querySelectorAll('.qty-input, .onetime_input, .subscription_input').forEach(input => {
      input.addEventListener('change', updatePrice);
    });
  });
  </script>
