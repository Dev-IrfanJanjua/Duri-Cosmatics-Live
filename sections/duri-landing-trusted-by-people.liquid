<style>
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-color }};
}

/* Main wrapper */
.cr-trusted-wrapper {
    display: flex;
    flex-direction: row-reverse;
}

.cr-trusted-media {
    line-height: 0;
}

img.cr-trusted-image {
    width: 100%;
    height: auto;
    max-width: 800px;
    min-width: 800px;
    max-height: 861px;
}

.cr-trusted-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: #fff4f3;
}

.cr-trusted-block {
    max-width: 480px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    background: #FFF;
}

.cr-trusted-heading {
    margin: 0;
    color: #000;
    font-family: "PP Mori";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: 46.8px;
    text-align: start;
    letter-spacing: 0;
}

.cr-trusted-items {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.cr-trusted-iconrow {
    display: flex;
    align-items: center;
    gap: 16px;
}

.cr-trusted-inner {
    text-align: center;
    max-width: 480px;
    margin-right: 80px;
    margin-left: 80px;
    gap: 24px;
    display: flex;
    flex-direction: column;
}

.cr-trusted-itemtitle {
    text-align: start;
    color: #000;
    font-family: "PP Mori";
    font-size: 20px;
    font-style: normal;
    font-weight: 600;
    line-height: 30px;
    margin: 0;
    letter-spacing: 0;
}

.cr-trusted-itemtext p {
    margin: 0;
    color: #000;
    font-family: "PP Mori";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 21px;
    text-align: start;
    letter-spacing: 0;
}

/* Highlight Variant */
.cr-trusted-highlight img.cr-trusted-image {
    width: 100%;
    height: auto;
    max-width: 610px;
    min-width: 610px;
    max-height: 610px;
}

.cr-trusted-highlight .cr-trusted-wrapper {
    display: flex;
    flex-direction: row-reverse;
    justify-content: center;
    align-items: center;
    gap: 60px;
}

.cr-trusted-highlight .cr-trusted-iconrow {
    display: unset; 
    align-items: unset; 
}

.cr-trusted-highlight .cr-trusted-inner {
    margin-right: 0px;
    margin-left: 0px;
    align-items: center;
    min-width: 600px;
}

.cr-trusted-highlight .cr-trusted-block {
    max-width: 100%;
    padding: 32px 32px 0 32px;
}

.cr-trusted-highlight .cr-trusted-inner {
    align-items: unset;
}

.cr-trusted-highlight .cr-trusted-items {
    gap: 0;
}

.cr-trusted-highlight .cr-trusted-itemtext p {
    padding-bottom: 16px;
    border-bottom: 1px solid #7BA69D66;
}

.cr-trusted-highlight .cr-trusted-block:last-child .cr-trusted-itemtext p {
    border-bottom: none;
}

/* Mobile */
@media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        background-color: {{ section.settings.back-color }};
    }

    .cr-trusted-wrapper {
        flex-direction: column;
    }

    img.cr-trusted-image {
        width: 100%;
        height: auto;
        max-width: unset;
        min-width: unset;
        max-height: unset;
    }

    .cr-trusted-inner {
        margin: 40px 16px;
        gap: 16px;
    }

    .cr-trusted-block {
        padding: 16px 16px;
    }

    .cr-trusted-items {
        gap: 16px;
    }

    .cr-trusted-heading {
        font-size: 24px;
        line-height: 31.6px;
        text-align: center;
        max-width: 300px; 
    }

    .cr-trusted-inner {
        align-items: center;
    }

    .cr-trusted-itemtitle {
        font-size: 18px;
        padding-bottom: unset;
    }

    .cr-titlewrap:nth-child(2) {
        padding-bottom: 5px;
    }

    .cr-trusted-highlight .cr-trusted-wrapper {
        flex-direction: column;
        gap: 40px;
    }

    .cr-trusted-highlight img.cr-trusted-image {
        max-width: unset;
        min-width: unset;
        max-height: unset;
    }

    .cr-trusted-highlight .cr-trusted-inner {
        min-width: unset;
        padding: 0 16px;
        margin: 0;
    }

    .cr-trusted-highlight .cr-trusted-heading {
        text-align: start;
        max-width: unset;
    }

    .cr-trusted-highlight .cr-trusted-block {
        padding: 22px 20px 0 20px;
    }
    .cr-trusted-heading {
        text-align: center;
        margin: 0 auto;
    }
    .cr-trusted-inner {
        align-items: unset;
    }
    .cr-trusted-icon svg {
        max-width: 24px;
    }
}
</style>

<section class="section-{{ section.id }}-padding {% if section.settings.enable_highlight_TRUSTED %}cr-trusted-highlight{% endif %}">
    <div class="cr-trusted-wrapper">
        <div class="cr-trusted-media">
            <img class="cr-trusted-image" src="{{ section.settings.trust-img | image_url }}" loading="lazy" width="100%" height="100%">
        </div>
        <div class="cr-trusted-content">
            <div class="cr-trusted-inner">
                <p class="cr-trusted-heading">{{ section.settings.heading }}</p>
                <div class="cr-trusted-items">
                    {% for block in section.blocks %}
                        <div class="cr-trusted-block">
                            <div class="cr-trusted-iconrow">
                                <div class="cr-trusted-icon"> {{ block.settings.custom_svg }} </div>
                                <div class="cr-titlewrap">
                                    <p class="cr-trusted-itemtitle">{{ block.settings.blockheading }}</p>
                                </div>
                            </div>
                            <div class="cr-textwrap">
                                <div class="cr-trusted-itemtext">{{ block.settings.subtext }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
  {
    "name": "Duri Landing Trusted ppl",
    "settings": [
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding Top",
        "default": 10
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding Bottom",
        "default": 10
      },
      {
        "type": "color", 
        "id": "back-color",
        "label": "Background Color"
      },
      {
        "type": "image_picker",
        "id": "trust-img",
        "label": "Main Image"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "checkbox",
        "id": "enable_highlight_TRUSTED",
        "label": "Enable Highlight",
        "default": false
      }
    ],
    "blocks": [
      {
        "type": "blocks",
        "name": "Add Item",
        "settings": [
          {
            "type": "html",
            "id": "custom_svg",
            "label": "SVG markup"
          },
          {
            "type": "text",
            "id": "blockheading",
            "label": "Block Heading"
          },
          {
            "type": "richtext",
            "id": "subtext",
            "label": "Subtext"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Duri Landing Trusted ppl"
      }
    ]
  }
{% endschema %}
