{% style %}
.section-{{ section.id }}--padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back-ground }};
    position: relative;
}
.cs_title strong {
    margin: 0;
    font-family: Poppins;
    font-size: 40px;
    font-weight: 700;
    line-height: 37px;
    letter-spacing: 0.5px;
    text-align: center;
    color: linear-gradient(90deg, #0D2628 5.47%, #32999E 52.73%, #0D2628 100%);
}
.cs_title {
    margin: 0;
    text-align: center;
    padding-bottom: 30px;
    color: #000 !important;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 36px;
    line-height: 46.8px;
}
.cs_card_footer {
    padding: 20px;
    padding-bottom: 0;
    text-align: center;
    background: transparent;
}
.cs_card_box {
    background: #FFF4F3;
    display: flex;
    flex-direction: column-reverse;
    border: 0.96px solid var(--Mid-Pink, #D99CA5);
    justify-content: space-between;
    gap: 27px;
}
.cs_card_box img {
    max-width: 100%;
    max-height: 290px;
    object-fit: cover;
    height: auto;
}
.cs_stars {
    line-height: 0;
    padding-bottom: 16px;
}
.cs_card_heading {
    margin: 0;
    text-transform: capitalize;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 20px;
    line-height: 30px;
    color: #000;
    text-align: left;
    letter-spacing: 0;
    margin-bottom: 12px;
}
.cs_desc {
    margin: 0;
    text-align: left;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 21px;
    color: #000;
}
.cs_meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.cs_user {
    margin: 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 16px;
    text-align: center;
    color: #000;
}
.cs_verified_text {
    margin: 0;
    font-family: PP Mori;
    font-weight: 400;
    font-size: 14px;
    line-height: 16px;
}
.cs_verified {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3px;
    border-radius: 1084px;
    padding: 2px 11px 2px 8px;
    line-height: 0;
}
.cs_slider .slick-next {
    bottom: 0 !important;
    right: 46%;
    width: 40px !important;
    height: 40px;
    background: #6c4e72;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
}
.cs_slider .slick-prev {
    bottom: 0 !important;
    left: 47%;
    width: 40px;
    height: 40px;
    background: #6c4e72;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
}
.cs_slider .slick-prev:before {
    display: none;
}
.cs_slider .slick-track {
    display: flex;
    gap: 14px;
}
.cs_top_shape svg {
    width: 100%;
    height: 100%;
    display: block;
}
.cs_top_shape {
    position: absolute;
    top: -77px;
    width: 100%;
}
.cs_top_shape_mbl {
    display: none;
}
.cs_card_number {
    font-family: PP Mori;
    font-weight: 600;
    font-size: 36px;
    line-height: 46.8px;
    margin: 0;
    padding-bottom: 12px;
    text-align: left;
}
.cs_main_btn {
    text-align: left;
}
a.cs_btn_link {
    text-decoration: none;
    color: #000;
    font-family: PP Mori;
    font-weight: 600;
    font-size: 14px;
    line-height: 20.8px;
}
p.cs_btn_text {
    margin: 0;
    padding-top: 40px;
}
.cs_main_btn {
    display: none;
}

.section-{{ section.id }}--padding .swiper-slide {
    display: flex;
    height: auto;
}

/* Responsive */
@media (max-width: 768px) {
    .section-{{ section.id }}--padding {
      padding-top: {{ section.settings.padding_top_mob }}px;
      padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    }
    .section-{{ section.id }}--padding .page-width {
    padding-right: 0;
}
    .cs_main_btn {
      display: block;
    }
    .cs_stars svg {
      height: 12px;
      width: 68px;
    }
    .cs_card_box img {
      max-height: 240px;
    }
.cs_title {
    font-size: 24px;
    line-height: 31.2px;
    font-weight: 600;
    max-width: 278px;
    text-align: center;
    margin: 0 auto;
    padding-right: 16px;
}
    .cs_card_heading {
      font-size: 18px;
      line-height: 24px;
      margin-bottom: 8px;
    }
    .cs_desc {
      font-size: 14px;
      line-height: 21px;
    }
    .cs_user {
      font-size: 12px;
      line-height: 18px;
    }
    .cs_title strong {
      font-size: 35px;
      line-height: 30px;
    }
    .cs_verified_text {
      font-size: 11px;
      line-height: 16px;
    }
.cs_card_box {
    margin-bottom: 0;
    gap: 20px;
}
    .cs_slider .slick-track {
      gap: 13px;
    }
    .cs_stars {
      margin: 21px 0 13px 0;
    }
    .cs_slider .slick-prev {
      left: 39%;
    }
    .cs_slider .slick-next {
      right: 39%;
    }
    .cs_top_shape {
      display: none;
    }
    .cs_top_shape_mbl {
      display: block;
      width: 100%;
      position: absolute;
      top: -48px;
    }
    .cs_top_shape_mbl svg {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
}
{% endstyle %}

{% comment %} <div class="cs_container"> {% endcomment %}
  <section class="section-{{ section.id }}--padding" id="ingredients_sec">
    <div class="page-width">
      <div class="cs_header">
        <div class="cs_title">{{ section.settings.heading }}</div>
      </div>

      <div class="cs_slider">
        <div class="swiper cs_swiper">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
            <div class="swiper-slide">
              <div class="cs_card_box">
                <img src="{{ block.settings.image | image_url }}" loading="lazy" width="100%" height="auto">
                <div class="cs_card_footer">
                  <h2 class="cs_card_number">{{ block.settings.block-headingNUmbr }}</h2>
                  <h2 class="cs_card_heading">{{ block.settings.block-heading }}</h2>
                  <div class="cs_desc">{{ block.settings.para }}</div>
                  <div class="cs_main_btn">
                    <a href="{{ block.settings.btn-ref-link }}" class="cs_btn_link"><p class="cs_btn_text">{{ block.settings.btn-lable }}</p></a>
                  </div>
                </div>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>
{% comment %} </div> {% endcomment %}

<script>
var swiper = new Swiper(".cs_swiper", {
  slidesPerView: 3,
  spaceBetween: 20,
  centeredSlides: true,
  loop: true,
  speed: 1500,
  navigation: {
    nextEl: ".cs_reviews_next",
    prevEl: ".cs_reviews_prev",
  },
  breakpoints: {
    0: {
      slidesPerView: 1.2,
      spaceBetween: 16,
      centeredSlides: false,
    },
    768: {
      slidesPerView: 2,
      spaceBetween: 16,
      centeredSlides: false,
    },
    1024: {
      slidesPerView: 3,
      spaceBetween: 20,
      centeredSlides: false,
    }
  },
});
</script>

{% schema %}
{
  "name": "Duri Product Pure Ingrdnt", 
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top Padding Mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom Padding Mobile",
      "default": 40
    },
    {
      "type": "color",
      "id": "back-ground",
      "label": "Background Color"
    }
  ],
  "blocks": [
    {
      "type": "cs_blocks",
      "name": "CS Blocks",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "block-headingNUmbr",
          "label": "Heading Number"
        },
        {
          "type": "text",
          "id": "block-heading",
          "label": "Heading"
        },
        {
          "type": "inline_richtext",
          "id": "para",
          "label": "Block Paragraph"
        },
        {
          "type": "url",
          "id": "btn-ref-link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "btn-lable",
          "label": "Button Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duri Product Pure Ingrdnt"
    }
  ]
}
{% endschema %}
