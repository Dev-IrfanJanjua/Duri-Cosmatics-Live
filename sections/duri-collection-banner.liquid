<section class="cbanner-sec-{{ section.id }} section-{{ section.id }}">
  <div class="page-width">
    <div class="cbanner-wrapper-991">
      
      <!-- Desktop Image -->
      {% if section.settings.desktop_image != blank or section.settings.mobile_image != blank %}
        <div class="col_banner-images">
          {% if section.settings.desktop_image != blank %}
            <img class="cbanner-img-desktop-991" src="{{ section.settings.desktop_image | image_url }}" alt="banner" loading="eager">
          {% endif %}
          
          <!-- Mobile Image -->
          {% if section.settings.mobile_image != blank %}
            <img class="cbanner-img-mobile-991" src="{{ section.settings.mobile_image | image_url }}" alt="banner mobile" loading="eager">
          {% endif %}
        </div>
      {% endif %}
  
      <!-- Content -->
      <div class="cbanner-content-991">
        {% if section.settings.heading != blank %}
          <h2 class="cbanner-heading-991">{{ section.settings.heading }}</h2>
        {% endif %}
  
        {% if section.blocks.size > 0 %}
          <div class="cbanner-icons-wrap-991">
            {% for block in section.blocks %}
              {% if block.settings.icon_svg != blank or block.settings.text != blank %}
                <div class="cbanner-icon-box-991">
                  
                    <div class="cbanner-svg-991">
                      {% render'myicon-svg' %}
                    </div>
                  
                  {% if block.settings.text != blank %}
                    <p class="cbanner-icon-text-991">{{ block.settings.text }}</p>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.section-{{ section.id }} {
  position: relative;
  overflow: hidden;
  background: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.section-{{ section.id }} .page-width {
    padding: 0 60px;
}

.col_banner-images {
    max-width: 100%;
    height: auto;
    width: 100%;
    position: relative;
}

.cbanner-img-desktop-991,
.cbanner-img-mobile-991 {
  width: 100%;
  height: 100%;
  display: block;
}

.cbanner-img-mobile-991 {
  display: none;
}

.cbanner-wrapper-991 {
    position: relative;
}

.cbanner-content-991 {
    position: absolute;
    bottom: 80px;
    left: 80px;
    z-index: 2;
    text-align: center;
    color: #fff;
    max-width: 546px;
    width: 100%;
}

.cbanner-heading-991 {
    font-family: "PP Mori", sans-serif;
    font-size: 46px;
    font-weight: 600;
    margin: 0 0 24px;
    color: #fff;
    text-align: start;
    line-height: 55px;
}

.cbanner-svg-991 {
    min-width: 15px;
    width: 15px;
    height: 15px;
    display: flex;
    overflow: hidden;
}

.cbanner-icons-wrap-991 {
  display: flex;
  justify-content: start;
  gap: 12px;
  flex-wrap: wrap;
}

.cbanner-icon-box-991 {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cbanner-svg-991 svg {
  width: 100%;
  height: 100%;
  fill: #fff;
}

.cbanner-icon-text-991 {
  font-family: "PP Mori", sans-serif;
  font-size: 16px;
  line-height: 20.4px;
  font-weight: 400;
  margin: 0;
  color: #fff;
}

@media (max-width: 768px) {
.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_mobile }}px;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
}

.section-{{ section.id }} .page-width {
    padding: 0px;
}
  .cbanner-img-desktop-991 {
    display: none;
  }
.cbanner-content-991 {
    left: 16px;
    max-width: 100%;
    width: unset;
    right: 16px !important;
    bottom: 43px;
}

  .cbanner-img-mobile-991 {
    display: block;
    padding: 0;
  }
.cbanner-heading-991 {
    font-size: 28px;
    line-height: 36.4px;
    margin-bottom: 10px;
}
  .cbanner-icons-wrap-991 {
    gap: 12px;
  }
  .cbanner-icon-text-991 {
    font-size: 14px;
    text-align: left;
  }
}
</style>

{% schema %}
{
  "name": "Duri Collection Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Banner Heading",
      "default": "Your Banner Heading Here"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Description Color",
      "default": "#fff"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "icon_with_text",
      "name": "SVG + Text Block",
      "settings": [
        {
          "type": "text",
          "id": "icon_svg",
          "label": "Render SVG snippet name (without .liquid)",
          "default": "my-svg"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text beside SVG",
          "default": "100% Vegan"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duri Collection Banner",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
